c/span\u003e \u003cspan class=\"nx\"\u003eid\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;time-clock-nonce\u0026#34;\u003c/span\u003e \u003cspan class=\"nx\"\u003evalue\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;\u0026lt;?php echo wp_create_nonce(\u0026#34;\u003c/span\u003e\u003cspan class=\"nx\"\u003etime\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u003c/span\u003e\u003cspan class=\"nx\"\u003eclock\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u003c/span\u003e\u003cspan class=\"nx\"\u003enonce\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;); ?\u0026gt;\u0026#34;\u003c/span\u003e\u003cspan class=\"o\"\u003e\u0026gt;\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003e{: file=\u0026ldquo;aio-settings.php\u0026rdquo;}\u003c/p\u003e\n\u003cp\u003eIf \u003ccode\u003e$nonce\u003c/code\u003e is invalid =\u0026gt; it goes to the \u003ccode\u003eelse\u003c/code\u003e branch returning a \u003cstrong\u003eJSON\u003c/strong\u003e error that contains \u003ccode\u003e$nonce\u003c/code\u003e.\u003c/p\u003e\n\u003cp\u003eClicking \u003ccode\u003e2 references\u003c/code\u003e shows that the function \u003ccode\u003epublic function aio_time_clock_lite_js()\u003c/code\u003e is registered as a callback for action hooks:\u003c/p\u003e\n\u003cp\u003e\u003cfigure\u003e\u003ca class=\"lightgallery\" href=\"/2025-10-07-cve-2025-6832/ref1.png\" title=\"Callback registration for ajax hooks\" data-thumbnail=\"/2025-10-07-cve-2025-6832/ref1.png\" data-sub-html=\"\u003ch2\u003eCallback registration for ajax hooks\u003c/h2\u003e\u003cp\u003eCallback registration for ajax hooks\u003c/p\u003e\"\u003e\u003cimg  loading=\"lazy\" src='/2025-10-07-cve-2025-6832/ref1.png' srcset=\"/2025-10-07-cve-2025-6832/ref1_hu_91089804340836c8.webp 800w, /2025-10-07-cve-2025-6832/ref1_hu_b19134697bafdb67.webp 1200w, /2025-10-07-cve-2025-6832/ref1_hu_2adeb1d20598823c.webp 1600w\"  alt=\"Callback registration for ajax hooks\" height=\"374\" width=\"1080\"\u003e\u003c/a\u003e\u003cfigcaption class=\"image-caption\"\u003eCallback registration for ajax hooks\u003c/figcaption\u003e\n\u003c/figure\u003e\n\u003cem\u003eThe function aio_time_clock_lite_js() is attached to two Ajax hooks (authenticated \u0026amp; unauthenticated)\u003c/em\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ccode\u003ewp_ajax_aio_time_clock_lite_js\u003c/code\u003e (authenticated).\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003ewp_ajax_nopriv_aio_time_clock_lite_js\u003c/code\u003e (unauthenticated). =\u0026gt; Focus\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"sources--sinks\" class=\"headerLink\"\u003e\n    \u003ca href=\"#sources--sinks\" class=\"header-mark\"\u003e\u003c/a\u003e12.3 Sources \u0026amp; Sinks\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eSource\u003c/strong\u003e: The \u003ccode\u003enonce\u003c/code\u003e parameter is taken directly from \u003ccode\u003e$_POST\u003c/code\u003e (unauthenticated request).\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eSink\u003c/strong\u003e: The \u003ccode\u003enonce\u003c/code\u003e value is reflected back in \u003ccode\u003eecho json_encode(...)\u003c/code\u003e.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"flow\" class=\"headerLink\"\u003e\n    \u003ca href=\"#flow\" class=\"header-mark\"\u003e\u003c/a\u003e12.4 Flow\u003c/h3\u003e\u003col\u003e\n\u003cli\u003eSend a POST request (unauthenticated) to \u003ccode\u003e/wp-admin/admin-ajax.php\u003c/code\u003e with \u003cstrong\u003eparams\u003c/strong\u003e:\u003c/li\u003e\n\u003c/ol\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003etext\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.show-line-numbers]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l1.05 1.93c3 5.76 6.29 7.88 12.25 7.88h4.73c10.33 0 15.94 2.44 15.94 9.09 0 4.72-4.2 8.22-14.36 8.22a41.54 41.54 0 0 1-15.47-3.12c-6.49-3.88-11.74-3.5-15.6 3.12l-5.59 9