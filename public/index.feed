l\"\u003e\u003cspan class=\"p\"\u003e\u0026lt;/\u003c/span\u003e\u003cspan class=\"nt\"\u003espan\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003e👉 The patch adds output escaping for \u003ccode\u003e$item-\u0026gt;model\u003c/code\u003e, ensuring it is \u003cstrong\u003eescaped\u003c/strong\u003e before being printed to HTML.\u003c/p\u003e\n\u003cp\u003e\u003cimg class=\"tw-inline\" loading=\"lazy\" src='/2025-10-08-cve-2025-9816/dif3.png' srcset=\"/2025-10-08-cve-2025-9816/dif3_hu_d5afb069a92b464c.webp 800w, /2025-10-08-cve-2025-9816/dif3_hu_e525c6567dd72a75.webp 1200w, /2025-10-08-cve-2025-9816/dif3_hu_5339cacc3fbf3f48.webp 1600w\"  alt=\"Diff — Sự thay đổi mã trong models.php\" height=\"85\" width=\"1771\"\u003e\u003c/p\u003e\n\u003ch3 id=\"vulnerable-code\" class=\"headerLink\"\u003e\n    \u003ca href=\"#vulnerable-code\" class=\"header-mark\"\u003e\u003c/a\u003e15.2 Vulnerable code\u003c/h3\u003e\u003cdiv class=\"code-block highlight is-closed show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941