3c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-20\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"o\"\u003e../../../../../../\u003c/span\u003e\u003cspan class=\"n\"\u003epayload\u003c/span\u003e\u003cspan class=\"o\"\u003e.\u003c/span\u003e\u003cspan class=\"n\"\u003epdf\u003c/span\u003e \u003cspan class=\"o\"\u003e-\u0026gt;\u003c/span\u003e \u003cspan class=\"n\"\u003epayload\u003c/span\u003e\u003cspan class=\"o\"\u003e.\u003c/span\u003e\u003cspan class=\"n\"\u003epdf\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003eThen it concatenates into \u003ccode\u003e$base_dir\u003c/code\u003e and resolves the absolute path with \u003ca href=\"https://www.php.net/manual/en/function.realpath.php\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003ccode\u003erealpath\u003c/code\u003e\u003c/a\u003e before \u003ccode\u003einclude()\u003c/code\u003e =\u0026gt; effectively eliminates the \u003cstrong\u003eLFI\u003c/strong\u003e possibility.\u003c/p\u003e\n\u003ch3 id=\"vulnerable-code\" class=\"headerLink\"\u003e\n    \u003ca href=\"#vulnerable-code\" class=\"header-mark\"\u003e\u003c/a\u003e17.2 Vulnerable Code\u003c/h3\u003e\u003cp\u003eThe vulnerable \u003ccode\u003eform-template.php\u003c/code\u003e shown above is invoked from \u003ccode\u003estdl-shortcode.php\u003c/code\u003e\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-closed show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    t