span\u003e\u003cspan class=\"o\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003eWPHOSTEL_ROOMS\u003c/span\u003e\u003cspan class=\"o\"\u003e.\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34; tR ON tR.id = tB.room_id WHERE is_static=0 \u003c/span\u003e\u003cspan class=\"si\"\u003e$where_sql\u003c/span\u003e\u003cspan class=\"s2\"\u003e \u003c/span\u003e\u003cspan class=\"si\"\u003e$orderby\u003c/span\u003e\u003cspan class=\"s2\"\u003e \u003c/span\u003e\u003cspan class=\"si\"\u003e$limit_sql\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e);\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003eThe query resides in the \u003ccode\u003edefault\u003c/code\u003e branch of the \u003ccode\u003eswitch\u003c/code\u003e structure.\u003c/p\u003e\n\u003cp\u003eAll this logic belongs to the static \u003ccode\u003emanage()\u003c/code\u003e method of the \u003ccode\u003eWPHostelBookings\u003c/code\u003e class.\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-closed show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569