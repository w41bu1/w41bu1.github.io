  print:!tw-hidden\" \n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-5\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"k\"\u003epublic\u003c/span\u003e \u003cspan class=\"k\"\u003efunction\u003c/span\u003e \u003cspan class=\"nf\"\u003emain\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e \u003cspan class=\"nv\"\u003e$query_args\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u003c/span\u003e \u003cspan class=\"s1\"\u003e\u0026#39;\u0026#39;\u003c/span\u003e \u003cspan class=\"p\"\u003e)\u003c/span\u003e \u003cspan class=\"p\"\u003e{\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"nv\"\u003e$this\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u0026gt;\u003c/span\u003e\u003cspan class=\"na\"\u003einit\u003c/span\u003e\u003cspan class=\"p\"\u003e();\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"nv\"\u003e$parsed\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u003c/span\u003e \u003cspan class=\"nv\"\u003e$this\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u0026gt;\u003c/span\u003e\u003cspan class=\"na\"\u003eparse_request\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e \u003cspan class=\"nv\"\u003e$query_args\u003c/span\u003e \u003cspan class=\"p\"\u003e);\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"k\"\u003eif\u003c/span\u003e \u003cspan class=\"p\"\u003e(\u003c/span\u003e \u003cspan class=\"nv\"\u003e$parsed\u003c/span\u003e \u003cspan class=\"p\"\u003e)\u003c/span\u003e \u003cspan class=\"p\"\u003e{\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nv\"\u003e$this\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u0026gt;\u003c/span\u003e\u003cspan class=\"na\"\u003equery_posts\u003c/span\u003e\u003cspan class=\"p\"\u003e();\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nv\"\u003e$this\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u0026gt;\u003c/span\u003e\u003cspan class=\"na\"\u003ehandle_404\u003c/span\u003e\u003cspan class=\"p\"\u003e();\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nv\"\u003e$this\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u0026gt;\u003c/span\u003e\u003cspan class=\"na\"\u003eregister_globals\u003c/span\u003e\u003cspan class=\"p\"\u003e();\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e}\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"nv\"\u003e$this\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u0026gt;\u003c/span\u003e\u003cspan class=\"na\"\u003esend_headers\u003c/span\u003e\u003cspan class=\"p\"\u003e();\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"nx\"\u003edo_action_ref_array\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e \u003cspan class=\"s1\"\u003e\u0026#39;wp\u0026#39;\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e \u003cspan class=\"k\"\u003earray\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e \u003cspan class=\"o\"\u003e\u0026amp;\u003c/span\u003e\u003cspan class=\"nv\"\u003e$this\u003c/span\u003e \u003cspan class=\"p\"\u003e)\u003c/span\u003e \u003cspan class=\"p\"\u003e);\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e}\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003e\u003ccode\u003emain()\u003c/code\u003e will \u003ccode\u003eparse_request\u003c/code\u003e and perform the query to fetch the current post information using \u003ccode\u003equery_posts()\u003c/code\u003e.\u003c/p\u003e\n\u003cp\u003e\u003cimg class=\"tw-inline\" loading=\"lazy\" src='/2025-10-09-cve-2024-4439/debug2.png' srcset=\"/2025-10-09-cve-2024-4439/debug2_hu_fd7ac60df39c4c7e.webp 800w, /2025-10-09-cve-2024-4439/debug2_hu_d772e2c16a05e1a2.webp 1200w, /2025-10-09-cve-2024-4439/debug2_hu_8eb501d87aaa706f.webp 1600w\"  alt=\"Fetching the post using query_posts()\" height=\"522\" width=\"1513\"\u003e\u003c/p\u003e\n\u003cp\u003e\u003ccode\u003e$wp_the_query\u003c/code\u003e is the \u003cstrong\u003emain WP_Query\u003c/strong\u003e object in WordPress, while \u003ccode\u003e$wp_query\u003c/code\u003e is simply a \u003cstrong\u003ereference\u003c/strong\u003e pointing to \u003ccode\u003e$wp_the_query\u003c/code\u003e. Therefore, when \u003ccode\u003e$wp_the_query\u003c/code\u003e is initialized and has data, \u003ccode\u003e$wp_query\u003c/code\u003e will have the same data.\u003c/p\u003e\n\u003cp\u003e\u003cimg class=\"tw-inline\" loading=\"lazy\" src='/2025-10-09-cve-2024-4439/debug3.png' srcset=\"/2025-10-09-cve-2024-4439/debug3_hu_e6f7b235ad0d2be.webp 800w, /2025-10-09-cve-2024-4439/debug3_hu_3bb6acaf7a53b38b.webp 1200w, /2025-10-09-cve-2024-4439/debug3_hu_95aacb2890554cc2.webp 1600w\"  alt=\"Reference value of $wp_query\" height=\"473\" width=\"1338\"\u003e\u003c/p\u003e\n\u003cp\u003eWe obtain the \u003ccode\u003epost_content\u003c/code\u003e value:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003ephp\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.show-line-numbers]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l1.05 1.93c3 5.76 6.29 7.88 12.25 7.88h4.73c10.33 0 15.94 2.44 15.94 9.09 0 4.72-4.2 8.22-14.36 8.22a41.54 41.54 0 0 1-15.47-3.12c-6.49-3.88-11.74-3.5-15.6 3.12l-5.59 9.31c-3.72 6.13-3.19 11.72 2.63 15.94 7.71 4.69 20.38 9.44 37 9.44 34.16 0 48.5-22.75 48.5-44.12-.03-14.38-9.12-29.76-28.73-34.88zM496 224H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zm0-160H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16V80a16 16 0 0 0-16-16zm0 320H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zM16 160h64a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H64V40a8 8 0 0 0-8-8H32a8 8 0 0 0-7.14 4.42l-8 16A8 8 0 0 0 24 64h8v64H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8zm-3.91 160H80a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H41.32c3.29-10.29 48.34-18.68 48.34-56.44 0-29.06-25-39.56-44.47-39.56-21.36 0-33.8 10-40.46 18.75-4.37 5.59-3 10.84 2.8 15.37l8.58 6.88c5.61 4.56 11 2.47 16.12-2.44a13.44 13.44 0 0 1 9.46-3.84c3.33 0 9.28 1.56 9.28 8.75C51 248.19 0 257.31 0 304.59v4C0 316 5.08 320 12.09 320z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n\n      \u003cbutton \n        class=\"\n          wrap-code-button\n          tw-select-none \n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.is-wrap]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle code wrap\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M16 132h416c8.837 0 16-7.163 16-16V76c0-8.837-7.163-16-16-16H16C7.163 60 0 67.163 0 76v40c0 8.837 7.163 16 16 16zm0 160h416c8.837 0 16-7.163 16-16v-40c0-8.837-7.163-16-16-16H16c-8.837 0-16 7.163-16 16v40c0 8.837 7.163 16 16 16zm0 160h416c8.837 0 16-7.163 16-16v-40c0-8.837-7.163-16-16-16H16c-8.837 0-16 7.163-16 16v40c0 8.837 7.163 16 16 16z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n      \n      \u003cbutton \n        class=\"\n          copy-code-button\n          tw-select-none\n          tw-mx-2 \n          tw-hidden\n          group-[.is-open]:tw-block\n          hover:tw-text-fgColor-link \n          print:!tw-hidden\"\n        title=\"Copy code\"\u003e\n          \u003cspan class=\"copy-icon tw-block\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M433.941 65.941l-51.882-51.882A48 48 0 0 0 348.118 0H176c-26.51 0-48 21.49-48 48v48H48c-26.51 0-48 21.49-48 48v320c0 26.51 21.49 48 48 48h224c26.51 0 48-21.49 48-48v-48h80c26.51 0 48-21.49 48-48V99.882a48 48 0 0 0-14.059-33.941zM266 464H54a6 6 0 0 1-6-6V150a6 6 0 0 1 6-6h74v224c0 26.51 21.49 48 48 48h96v42a6 6 0 0 1-6 6zm128-96H182a6 6 0 0 1-6-6V54a6 6 0 0 1 6-6h106v88c0 13.255 10.745 24 24 24h88v202a6 6 0 0 1-6 6zm6-256h-64V48h9.632c1.591 0 3.117.632 4.243 1.757l48.368 48.368a6 6 0 0 1 1.757 4.243V112z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n          \u003cspan class=\"check-icon tw-hidden\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n      \u003c/button\u003e\n        \n      \u003cbutton \n        class=\"\n          tw-select-none \n          tw-mx-2 \n          tw-block \n          group-[.is-open]:tw-hidden \n          print:!tw-hidden\" \n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-6\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"o\"\u003e\u0026lt;!--\u003c/span\u003e \u003cspan class=\"nx\"\u003ewp\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e\u003cspan class=\"nx\"\u003eavatar\u003c/span\u003e \u003cspan class=\"p\"\u003e{\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;userId\u0026#34;\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e\u003cspan class=\"mi\"\u003e2\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;isLink\u0026#34;\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e\u003cspan class=\"k\"\u003etrue\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;linkTarget\u0026#34;\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;_blank\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e}\u003c/span\u003e \u003cspan class=\"o\"\u003e/--\u0026gt;\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003e\u003ccode\u003ewp:avatar\u003c/code\u003e is the \u003ccode\u003ecore/avatar\u003c/code\u003e block type.\u003c/p\u003e\n\u003cp\u003eThe \u003ccode\u003erender()\u003c/code\u003e function will call \u003ccode\u003ecall_user_func()\u003c/code\u003e with the callback \u003ccode\u003erender_block_core_avatar()\u003c/code\u003e to get the Avatar block HTML and return it to the user.\u003c/p\u003e\n\u003ch3 id=\"sources--sinks\" class=\"headerLink\"\u003e\n    \u003ca href=\"#sources--sinks\" class=\"header-mark\"\u003e\u003c/a\u003e3.3 Sources \u0026amp; Sinks\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eSource\u003c/strong\u003e: author name of a contributor+\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eSink\u003c/strong\u003e: \u003ccode\u003e$author_name\u003c/code\u003e injected into the \u003ccode\u003earia-label\u003c/code\u003e attribute\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"exploit\" class=\"headerLink\"\u003e\n    \u003ca href=\"#exploit\" class=\"header-mark\"\u003e\u003c/a\u003e4 Exploit\u003c/h2\u003e\u003ch3 id=\"proof-of-concept-poc\" class=\"headerLink\"\u003e\n    \u003ca href=\"#proof-of-concept-poc\" class=\"header-mark\"\u003e\u003c/a\u003e4.1 Proof of Concept (PoC)\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003eCreate a post account with role \u003ccode\u003econtributor+\u003c/code\u003e containing an avatar block, enable the \u003cstrong\u003eLink to user profile\u003c/strong\u003e option and select the contributor user.\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cimg class=\"tw-inline\" loading=\"lazy\" src='/2025-10-09-cve-2024-4439/post1.png' srcset=\"/2025-10-09-cve-2024-4439/post1_hu_6c45ece3d6427d7e.webp 800w, /2025-10-09-cve-2024-4439/post1_hu_acf165ebfc7eda92.webp 1200w, /2025-10-09-cve-2024-4439/post1_hu_449e8cfda34b5fba.webp 1600w\"  alt=\"Create a post with link to user profile enabled\" height=\"422\" width=\"1468\"\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eChange the first name to contain an XSS payload and set the display name to the first name.\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cimg class=\"tw-inline\" loading=\"lazy\" src='/2025-10-09-cve-2024-4439/disname.png' srcset=\"/2025-10-09-cve-2024-4439/disname_hu_f8576c9c6594d793.webp 800w, /2025-10-09-cve-2024-4439/disname_hu_d77a40150f41a1c5.webp 1200w, /2025-10-09-cve-2024-4439/disname_hu_b3f7be63dc12a0e1.webp 1600w\"  alt=\"Select a display name containing an XSS payload\" height=\"244\" width=\"603\"\u003e\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eAdmin previews the post =\u0026gt; XSS occurs\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cimg class=\"tw-inline\" loading=\"lazy\" src='/2025-10-09-cve-2024-4439/xss1.png' srcset=\"/2025-10-09-cve-2024-4439/xss1_hu_cf980b1da7f8faa3.webp 800w, /2025-10-09-cve-2024-4439/xss1_hu_db4fccfda635d49e.webp 1200w, /2025-10-09-cve-2024-4439/xss1_hu_6c131faa999147f1.webp 1600w\"  alt=\"XSS occurs when admin previews the post\" height=\"588\" width=\"1385\"\u003e\u003c/p\u003e\n\u003ch2 id=\"conclusion\" class=\"headerLink\"\u003e\n    \u003ca href=\"#conclusion\" class=\"header-mark\"\u003e\u003c/a\u003e5 Conclusion\u003c/h2\u003e\u003cp\u003eThe \u003cstrong\u003eCVE-2024-4439\u003c/strong\u003e vulnerability in \u003cstrong\u003eWordPress Core \u0026lt;= 6.5.1\u003c/strong\u003e stems from incorrect use of the \u003ccode\u003eesc_attr__()\u003c/code\u003e function when handling \u003ccode\u003edisplay_name\u003c/code\u003e in the \u003cstrong\u003eAvatar block\u003c/strong\u003e, resulting in a \u003cstrong\u003eStored XSS\u003c/strong\u003e. An attacker can exploit this by inserting a payload in the \u003ccode\u003edisplay_name\u003c/code\u003e, causing malicious scripts to execute when users (including admins) visit a page containing the block. The patch in \u003cstrong\u003e6.0.8, 6.1.6, 6.2.5, 6.3.4, 6.4.4, 6.5.2\u003c/strong\u003e changes the handling — escaping after formatting with \u003ccode\u003esprintf()\u003c/code\u003e — ensuring the data is safe before rendering to the browser.\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eKey takeaways\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eEscape order matters\u003c/strong\u003e: data should be \u003cstrong\u003eformatted first\u003c/strong\u003e, then \u003cstrong\u003eescaped\u003c/strong\u003e to avoid introducing XSS.\u003c/li\u003e\n\u003cli\u003eEven \u003cstrong\u003ecore functions\u003c/strong\u003e like \u003ccode\u003eesc_attr__()\u003c/code\u003e can lead to serious vulnerabilities if used incorrectly.\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eStored XSS\u003c/strong\u003e is particularly dangerous because it persists in the database and can trigger whenever a user views the affected content.\u003c/li\u003e\n\u003cli\u003eNot only plugins/themes, but \u003cstrong\u003eWordPress Core\u003c/strong\u003e must be \u003cstrong\u003eupdated regularly\u003c/strong\u003e to reduce security risk.\u003c/li\u003e\n\u003cli\u003eAnalyzing \u003cstrong\u003epatch diffs\u003c/strong\u003e is an effective way to learn secure coding practices and understand the root cause of bugs.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"references\" class=\"headerLink\"\u003e\n    \u003ca href=\"#references\" class=\"header-mark\"\u003e\u003c/a\u003e6 References\u003c/h2\u003e\u003cp\u003e\u003ca href=\"https://portswigger.net/web-security/cross-site-scripting/cheat-sheet\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCross-site scripting (XSS) cheat sheet — PortSwigger\u003c/a\u003e\u003c/p\u003e",
        "language": "en"
    },
    {
        "title" : "CVE-2025-9816 Analysis \u0026 POC",
        "date_published" : "2025-10-08T17:57:00+07:00",
        "date_modified" : "2025-10-21T19:11:48+07:00",
        "id" : "http://localhost:1313/2025-10-08-cve-2025-9816/",
        "url" : "http://localhost:1313/2025-10-08-cve-2025-9816/",
        "content_html" : "\u003ch2 id=\"cve--basic-info\" class=\"headerLink\"\u003e\n    \u003ca href=\"#cve--basic-info\" class=\"header-mark\"\u003e\u003c/a\u003e13 CVE \u0026amp; Basic Info\u003c/h2\u003e\u003cp\u003e\u003cstrong\u003eWP Statistics – The Most Popular Privacy-Friendly Analytics Plugin\u003c/strong\u003e for WordPress has a \u003cstrong\u003eStored Cross-Site Scripting (XSS)\u003c/strong\u003e vulnerability via the \u003cstrong\u003eUser-Agent Header\u003c/strong\u003e in all versions up to and including \u003cstrong\u003e14.15.4\u003c/strong\u003e. The root cause is insufficient \u003cstrong\u003einput validation/filtering\u003c/strong\u003e and \u003cstrong\u003eoutput escaping\u003c/strong\u003e.\u003c/p\u003e\n\u003cp\u003eThis vulnerability allows an \u003cstrong\u003eunauthenticated attacker\u003c/strong\u003e to inject malicious JavaScript into the system. The injected scripts will execute whenever a user visits a page containing the malicious data, posing severe security and privacy risks.\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eCVE ID\u003c/strong\u003e: \u003ca href=\"https://www.cve.org/CVERecord?id=CVE-2025-9816\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCVE-2025-9816\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eVulnerability Type\u003c/strong\u003e: Cross Site Scripting (XSS)\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eAffected Versions\u003c/strong\u003e: \u0026lt;= 14.15.4\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003ePatched Versions\u003c/strong\u003e: 14.15.5\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eCVSS severity\u003c/strong\u003e: Medium (7.1)\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eRequired Privilege\u003c/strong\u003e: Unauthenticated\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eProduct\u003c/strong\u003e: \u003ca href=\"https://wordpress.org/plugins/wp-statistics/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eWordPress WP Statistics Plugin\u003c/a\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"requirements\" class=\"headerLink\"\u003e\n    \u003ca href=\"#requirements\" class=\"header-mark\"\u003e\u003c/a\u003e14 Requirements\u003c/h2\u003e\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eLocal WordPress \u0026amp; Debugging\u003c/strong\u003e: \u003ca href=\"https://w41bu1.github.io/2025-08-21-wordpress-local-and-debugging/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eLocal WordPress and Debugging\u003c/a\u003e.\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003ePlugin versions\u003c/strong\u003e - \u003cstrong\u003eWP Statistics\u003c/strong\u003e: \u003cstrong\u003ev14.15.4\u003c/strong\u003e (vulnerable) and \u003cstrong\u003ev14.15.5\u003c/strong\u003e (patched).\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eDiff tool\u003c/strong\u003e - \u003ca href=\"https://meldmerge.org/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003eMeld\u003c/strong\u003e\u003c/a\u003e or any diff comparison tool to inspect differences between the two versions.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"analysis\" class=\"headerLink\"\u003e\n    \u003ca href=\"#analysis\" class=\"header-mark\"\u003e\u003c/a\u003e15 Analysis\u003c/h2\u003e\u003cp\u003eI initially missed some details while collecting information about this CVE; the \u003ca href=\"https://plugins.trac.wordpress.org/browser/wp-statistics/tags/14.15.3/includes/admin/templates/pages/devices/models.php#L31\" target=\"_blank\" rel=\"noopener noreferrer\"\u003ereferences\u003c/a\u003e of \u003ca href=\"https://www.cve.org/CVERecord?id=CVE-2025-9816\" target=\"_blank\" rel=\"noopener noreferrer\"\u003ehttps://www.cve.org/CVERecord?id=CVE-2025-9816\u003c/a\u003e point to where the vulnerability occurs: \u003ccode\u003eincludes/admin/templates/pages/devices/models.php\u003c/code\u003e{: .filepath}\u003c/p\u003e\n\u003cp\u003eBut I overlooked it and used \u003ca href=\"https://meldmerge.org/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003eMeld\u003c/strong\u003e\u003c/a\u003e to compare code. Because the code changed a lot, I proactively searched for files related to \u003cstrong\u003euser-agent\u003c/strong\u003e.\u003c/p\u003e\n\u003cp\u003e\u003cimg class=\"tw-inline\" loading=\"lazy\" src='/2025-10-08-cve-2025-9816/dif1.png' srcset=\"/2025-10-08-cve-2025-9816/dif1_hu_ad2279debc6a562d.webp 800w, /2025-10-08-cve-2025-9816/dif1_hu_129c9f1a61a9ceeb.webp 1200w, /2025-10-08-cve-2025-9816/dif1_hu_c4bc68e01ba03d08.webp 1600w\"  alt=\"Diff — so sánh thay đổi mã giữa bản vulnerable và bản vá\" height=\"887\" width=\"1839\"\u003e\u003c/p\u003e\n\u003cp\u003eThe changes in \u003ccode\u003eUserAgent.php\u003c/code\u003e made me believe the vulnerability truly occurs there.\u003c/p\u003e\n\u003cp\u003e\u003cimg class=\"tw-inline\" loading=\"lazy\" src='/2025-10-08-cve-2025-9816/dif2.png' srcset=\"/2025-10-08-cve-2025-9816/dif2_hu_b371ae3d7ff55fb6.webp 800w, /2025-10-08-cve-2025-9816/dif2_hu_fc82d81dbf9d3524.webp 1200w, /2025-10-08-cve-2025-9816/dif2_hu_b2a539489f49ed43.webp 1600w\"  alt=\"Diff — Sự thay đổi mã trong UserAgent.php\" height=\"341\" width=\"1730\"\u003e\u003c/p\u003e\n\u003cp\u003eIt cost me quite a bit of time but I couldn’t fully analyze it at that point. However, this effort helped the overall analysis.\u003c/p\u003e\n\u003cp\u003e🍀 Fortunately, guided by senior researchers, I \u003cstrong\u003efocused\u003c/strong\u003e on the correct \u003ca href=\"https://plugins.trac.wordpress.org/browser/wp-statistics/tags/14.15.3/includes/admin/templates/pages/devices/models.php#L31\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003evulnerability location\u003c/strong\u003e\u003c/a\u003e. That made the analysis easier.\u003c/p\u003e\n\u003cblockquote\u003e\n  \u003cp\u003eTip: This is a Cross Site Scripting vulnerability that happens in the victim’s browser, so you need to find where it is first rendered into HTML.\u003c/p\u003e\n\n\u003c/blockquote\u003e\u003ch3 id=\"patch-diff\" class=\"headerLink\"\u003e\n    \u003ca href=\"#patch-diff\" class=\"header-mark\"\u003e\u003c/a\u003e15.1 Patch diff\u003c/h3\u003e\u003cp\u003eThe vulnerability occurs in file \u003ccode\u003eincludes/admin/templates/pages/devices/models.php\u003c/code\u003e{: .filepath} at line 31.\u003c/p\u003e\n\u003cp\u003eIn the \u003cstrong\u003evulnerable\u003c/strong\u003e version, \u003ccode\u003e$item-\u0026gt;model\u003c/code\u003e is printed into HTML without any protection:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003ehtml\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.show-line-numbers]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l1.05 1.93c3 5.76 6.29 7.88 12.25 7.88h4.73c10.33 0 15.94 2.44 15.94 9.09 0 4.72-4.2 8.22-14.36 8.22a41.54 41.54 0 0 1-15.47-3.12c-6.49-3.88-11.74-3.5-15.6 3.12l-5.59 9.31c-3.72 6.13-3.19 11.72 2.63 15.94 7.71 4.69 20.38 9.44 37 9.44 34.16 0 48.5-22.75 48.5-44.12-.03-14.38-9.12-29.76-28.73-34.88zM496 224H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zm0-160H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16V80a16 16 0 0 0-16-16zm0 320H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zM16 160h64a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H64V40a8 8 0 0 0-8-8H32a8 8 0 0 0-7.14 4.42l-8 16A8 8 0 0 0 24 64h8v64H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8zm-3.91 160H80a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H41.32c3.29-10.29 48.34-18.68 48.34-56.44 0-29.06-25-39.56-44.47-39.56-21.36 0-33.8 10-40.46 18.75-4.37 5.59-3 10.84 2.8 15.37l8.58 6.88c5.61 4.56 11 2.47 16.12-2.44a13.44 13.44 0 0 1 9.46-3.84c3.33 0 9.28 1.56 9.28 8.75C51 248.19 0 257.31 0 304.59v4C0 316 5.08 320 12.09 320z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n\n      \u003cbutton \n        class=\"\n          wrap-code-button\n          tw-select-none \n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.is-wrap]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle code wrap\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M16 132h416c8.837 0 16-7.163 16-16V76c0-8.837-7.163-16-16-16H16C7.163 60 0 67.163 0 76v40c0 8.837 7.163 16 16 16zm0 160h416c8.837 0 16-7.163 16-16v-40c0-8.837-7.163-16-16-16H16c-8.837 0-16 7.163-16 16v40c0 8.837 7.163 16 16 16zm0 160h416c8.837 0 16-7.163 16-16v-40c0-8.837-7.163-16-16-16H16c-8.837 0-16 7.163-16 16v40c0 8.837 7.163 16 16 16z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n      \n      \u003cbutton \n        class=\"\n          copy-code-button\n          tw-select-none\n          tw-mx-2 \n          tw-hidden\n          group-[.is-open]:tw-block\n          hover:tw-text-fgColor-link \n          print:!tw-hidden\"\n        title=\"Copy code\"\u003e\n          \u003cspan class=\"copy-icon tw-block\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M433.941 65.941l-51.882-51.882A48 48 0 0 0 348.118 0H176c-26.51 0-48 21.49-48 48v48H48c-26.51 0-48 21.49-48 48v320c0 26.51 21.49 48 48 48h224c26.51 0 48-21.49 48-48v-48h80c26.51 0 48-21.49 48-48V99.882a48 48 0 0 0-14.059-33.941zM266 464H54a6 6 0 0 1-6-6V150a6 6 0 0 1 6-6h74v224c0 26.51 21.49 48 48 48h96v42a6 6 0 0 1-6 6zm128-96H182a6 6 0 0 1-6-6V54a6 6 0 0 1 6-6h106v88c0 13.255 10.745 24 24 24h88v202a6 6 0 0 1-6 6zm6-256h-64V48h9.632c1.591 0 3.117.632 4.243 1.757l48.368 48.368a6 6 0 0 1 1.757 4.243V112z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n          \u003cspan class=\"check-icon tw-hidden\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n      \u003c/button\u003e\n        \n      \u003cbutton \n        class=\"\n          tw-select-none \n          tw-mx-2 \n          tw-block \n          group-[.is-open]:tw-hidden \n          print:!tw-hidden\" \n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-69\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e\u0026lt;\u003c/span\u003e\u003cspan class=\"nt\"\u003espan\u003c/span\u003e \u003cspan class=\"na\"\u003etitle\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;\u0026lt;?php echo \\WP_STATISTICS\\Admin_Template::unknownToNotSet($item-\u0026gt;model); ?\u0026gt;\u0026#34;\u003c/span\u003e \u003cspan class=\"na\"\u003eclass\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;wps-model-name\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"cp\"\u003e\u0026lt;?php echo self::isUnknown($item-\u0026gt;model) ? esc_html__(\u0026#39;Unknown\u0026#39;, \u0026#39;wp-statistics\u0026#39;) : $item-\u0026gt;model; ?\u0026gt;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e\u0026lt;/\u003c/span\u003e\u003cspan class=\"nt\"\u003espan\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003eIn the \u003cstrong\u003epatched\u003c/strong\u003e version, \u003ccode\u003e$item-\u0026gt;model\u003c/code\u003e is protected by wrapping it with \u003ccode\u003eesc_attr()\u003c/code\u003e and \u003ccode\u003eesc_html()\u003c/code\u003e.\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003ehtml\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.show-line-numbers]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l1.05 1.93c3 5.76 6.29 7.88 12.25 7.88h4.73c10.33 0 15.94 2.44 15.94 9.09 0 4.72-4.2 8.22-14.36 8.22a41.54 41.54 0 0 1-15.47-3.12c-6.49-3.88-11.74-3.5-15.6 3.12l-5.59 9.31c-3.72 6.13-3.19 11.72 2.63 15.94 7.71 4.69 20.38 9.44 37 9.44 34.16 0 48.5-22.75 48.5-44.12-.03-14.38-9.12-29.76-28.73-34.88zM496 224H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320