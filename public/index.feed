\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-4\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"k\"\u003efinal\u003c/span\u003e \u003cspan class=\"k\"\u003eclass\u003c/span\u003e \u003cspan class=\"nc\"\u003eWPPM_Admin\u003c/span\u003e \u003cspan class=\"p\"\u003e{\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"k\"\u003epublic\u003c/span\u003e \u003cspan class=\"k\"\u003efunction\u003c/span\u003e \u003cspan class=\"fm\"\u003e__construct\u003c/span\u003e\u003cspan class=\"p\"\u003e()\u003c/span\u003e \u003cspan class=\"p\"\u003e{\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e        \u003cspan class=\"c1\"\u003e// other actions\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e        \u003cspan class=\"nx\"\u003eadd_action\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e \u003cspan class=\"s1\"\u003e\u0026#39;wp_ajax_wppm_get_users\u0026#39;\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e \u003cspan class=\"k\"\u003earray\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"nv\"\u003e$this\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e\u003cspan class=\"s1\"\u003e\u0026#39;wppm_get_users\u0026#39;\u003c/span\u003e\u003cspan class=\"p\"\u003e));\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e        \u003cspan class=\"c1\"\u003e// other actions\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e    \u003cspan class=\"p\"\u003e}\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e}\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cp\u003e\u003ccode\u003eadd_action()\u003c/code\u003e is a \u003cstrong\u003eWordPress Plugin API\u003c/strong\u003e method to attach a \u003cstrong\u003ecallback\u003c/strong\u003e to an \u003cstrong\u003eaction hook\u003c/strong\u003e.\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003e\u003ccode\u003ewp_ajax_wppm_get_users\u003c/code\u003e is an Ajax hook name:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ccode\u003ewp_ajax_{action}\u003c/code\u003e → handles Ajax for logged-in users.\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003ewp_ajax_nopriv_{action}\u003c/code\u003e → handles Ajax for non-logged-in users.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003eHere, \u003ccode\u003eaction = wppm_get_users\u003c/code\u003e. If you send \u003ccode\u003eaction=wppm_get_users\u003c/code\u003e via Ajax to \u003ccode\u003eadmin-ajax.php\u003c/code\u003e, WordPress will execute the corresponding callback, here \u003ccode\u003ewppm_get_users()\u003c/code\u003e.\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e👉 Knowing \u003ccode\u003eaction = wppm_get_users\u003c/code\u003e, you can find which Ajax requests use it by searching \u003ccode\u003ewppm_get_users\u003c/code\u003e in \u003cstrong\u003e.js\u003c/strong\u003e files of the plugin.\u003c/p\u003e\n\u003cp\u003e\u003cfigure\u003e\u003ca class=\"lightgallery\" href=\"/2025-09-22-cve-2025-39569/ajax_search.png\" title=\"ajax search\" data-thumbnail=\"/2025-09-22-cve-2025-39569/ajax_search.png\" data-sub-html=\"\u003ch2\u003eAjax search\u003c/h2\u003e\u003cp\u003eajax search\u003c/p\u003e\"\u003e\u003cimg  loading=\"lazy\" src='/2025-09-22-cve-2025-39569/ajax_search.png' srcset=\"/2025-09-22-cve-2025-39569/ajax_search_hu_9fbe9b9b5eede8e0.webp 800w, /2025-09-22-cve-2025-39569/ajax_search_hu_280c9c9291903c88.webp 1200w, /2025-09-22-cve-2025-39569/ajax_search_hu_291fa1da295fb8ae.webp 1600w\"  alt=\"ajax search\" height=\"567\" width=\"952\"\u003e\u003c/a\u003e\u003cfigcaption class=\"image-caption\"\u003eAjax search\u003c/figcaption\u003e\n\u003c/figure\u003e\u003c/p\u003e\n\u003cp\u003eThe \u003ccode\u003ewppm_get_users\u003c/code\u003e action is the \u003cstrong\u003edata part\u003c/strong\u003e in the POST request handled by \u003ccode\u003ewppm_get_users()\u003c/code\u003e.\u003c/p\u003e\n\u003cp\u003eThe function is referenced in HTML attributes of the \u003cstrong\u003eproject feature\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eCreate a new project\u003c/li\u003e\n\u003cli\u003eAccess that project\u003c/li\u003e\n\u003cli\u003eInspect code to locate \u003ccode\u003ewppm_get_users\u003c/code\u003e and see which actions call it\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cfigure\u003e\u003ca class=\"lightgallery\" href=\"/2025-09-22-cve-2025-39569/ajax_inspect.png\" title=\"ajax inspect\" data-thumbnail=\"/2025-09-22-cve-2025-39569/ajax_inspect.png\" data-sub-html=\"\u003ch2\u003eAjax inspect\u003c/h2\u003e\u003cp\u003eajax inspect\u003c/p\u003e\"\u003e\u003cimg  loading=\"lazy\" src='/2025-09-22-cve-2025-39569/ajax_inspect.png' srcset=\"/2025-09-22-cve-2025-39569/ajax_inspect_hu_20af47b78994c7c5.webp 800w, /2025-09-22-cve-2025-39569/ajax_inspect_hu_6c4c65c66d7dd81f.webp 1200w, /2025-09-22-cve-2025-39569/ajax_inspect_hu_25db13873ab05af0.webp 1600w\"  alt=\"ajax inspect\" height=\"401\" width=\"825\"\u003e\u003c/a\u003e\u003cfigcaption class=\"image-caption\"\u003eAjax inspect\u003c/figcaption\u003e\n\u003c/figure\u003e\u003c/p\u003e\n\u003cp\u003e👉 Clicking the \u003cstrong\u003eicon next to Users\u003c/strong\u003e triggers Ajax, sending a request to the server to fetch project users and render them in HTML.\u003c/p\u003e\n\u003cp\u003e\u003cfigure\u003e\u003ca class=\"lightgallery\" href=\"/2025-09-22-cve-2025-39569/model_display.png\" title=\"modal display\" data-thumbnail=\"/2025-09-22-cve-2025-39569/model_display.png\" data-sub-html=\"\u003ch2\u003eModel display\u003c/h2\u003e\u003cp\u003emodal display\u003c/p\u003e\"\u003e\u003cimg  loading=\"lazy\" src='/2025-09-22-cve-2025-39569/model_display.png' srcset=\"/2025-09-22-cve-2025-39569/model_display_hu_d6ac88bb7f37024e.webp 800w, /2025-09-22-cve-2025-39569/model_display_hu_107f59f76ad2c6d8.webp 1200w, /2025-09-22-cve-2025-39569/model_display_hu_af8d545414ab00d1.webp 1600w\"  alt=\"modal display\" height=\"536\" width=\"962\"\u003e\u003c/a\u003e\u003cfigcaption class=\"image-caption\"\u003eModel display\u003c/figcaption\u003e\n\u003c/figure\u003e\u003c/p\u003e\n\u003ch2 id=\"exploit\" class=\"headerLink\"\u003e\n    \u003ca href=\"#exploit\" class=\"header-mark\"\u003e\u003c/a\u003e3 Exploit\u003c/h2\u003e\u003ch3 id=\"detect-sqli\" class=\"headerLink\"\u003e\n    \u003ca href=\"#detect-sqli\" class=\"header-mark\"\u003e\u003c/a\u003e3.1 Detect SQLi\u003c/h3\u003e\u003cp\u003eCapture requests using BurpSuite and send a \u003cstrong\u003etime-based SQLi payload\u003c/strong\u003e:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003ehttp\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.show-line-numbers]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l