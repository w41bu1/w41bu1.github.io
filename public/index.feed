03c/span\u003e\u003cspan class=\"p\"\u003e))\u003c/span\u003e \u003cspan class=\"k\"\u003einclude\u003c/span\u003e \u003cspan class=\"nx\"\u003eget_stylesheet_directory\u003c/span\u003e\u003cspan class=\"p\"\u003e()\u003c/span\u003e\u003cspan class=\"o\"\u003e.\u003c/span\u003e\u003cspan class=\"s1\"\u003e\u0026#39;/wphostel/bookings.html.php\u0026#39;\u003c/span\u003e\u003cspan class=\"p\"\u003e;\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"k\"\u003eelse\u003c/span\u003e \u003cspan class=\"k\"\u003einclude\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"nx\"\u003eWPHOSTEL_PATH\u003c/span\u003e\u003cspan class=\"o\"\u003e.\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;/views/bookings.html.php\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e);\u003c/span\u003e\t\n\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003e\u003ccode\u003eWPHOSTEL_PATH\u003c/code\u003e is the absolute path to the plugin directory.\u003c/p\u003e\n\u003cp\u003e\u003cfigure\u003e\u003ca class=\"lightgallery\" href=\"/2025-10-02-cve-2025-6234/search_path.png\" title=\"search path\" data-thumbnail=\"/2025-10-02-cve-2025-6234/search_path.png\" data-sub-html=\"\u003ch2\u003eAbsolute path to the plugin directory\u003c/h2\u003e\u003cp\u003esearch path\u003c/p\u003e\"\u003e\u003cimg  loading=\"lazy\" src='/2025-10-02-cve-2025-6234/search_path.png' srcset=\"/2025-10-02-cve-2025-6234/search_path_hu_5e8f1475f86486c3.webp 800w, /2025-10-02-cve-2025-6234/search_path_hu_ff16b7c9acbb220f.webp 1200w, /2025-10-02-cve-2025-6234/search_path_hu_88b8f2201e10b5e3.webp 1600w\"  alt=\"search path\" height=\"329\" width=\"987\"\u003e\u003c/a\u003e\u003cfigcaption class=\"image-caption\"\u003eAbsolute path to the plugin directory\u003c/figcaption\u003e\n\u003c/figure\u003e\u003c/p\u003e\n\u003ch2 id=\"exploit\" class=\"headerLink\"\u003e\n  