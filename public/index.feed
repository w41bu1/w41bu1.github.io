dden\"\n        title=\"Copy code\"\u003e\n          \u003cspan class=\"copy-icon tw-block\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M433.941 65.941l-51.882-51.882A48 48 0 0 0 348.118 0H176c-26.51 0-48 21.49-48 48v48H48c-26.51 0-48 21.49-48 48v320c0 26.51 21.49 48 48 48h224c26.51 0 48-21.49 48-48v-48h80c26.51 0 48-21.49 48-48V99.882a48 48 0 0 0-14.059-33.941zM266 464H54a6 6 0 0 1-6-6V150a6 6 0 0 1 6-6h74v224c0 26.51 21.49 48 48 48h96v42a6 6 0 0 1-6 6zm128-96H182a6 6 0 0 1-6-6V54a6 6 0 0 1 6-6h106v88c0 13.255 10.745 24 24 24h88v202a6 6 0 0 1-6 6zm6-256h-64V48h9.632c1.591 0 3.117.632 4.243 1.757l48.368 48.368a6 6 0 0 1 1.757 4.243V112z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n          \u003cspan class=\"check-icon tw-hidden\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n      \u003c/button\u003e\n        \n      \u003cbutton \n        class=\"\n          tw-select-none \n          tw-mx-2 \n          tw-block \n          group-[.is-open]:tw-hidden \n          print:!tw-hidden\" \n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-7\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nf\"\u003ePOST\u003c/span\u003e \u003cspan class=\"nn\"\u003e/wp-admin/admin-ajax.php\u003c/span\u003e \u003cspan class=\"kr\"\u003eHTTP\u003c/span\u003e\u003cspan class=\"o\"\u003e/\u003c/span\u003e\u003cspan class=\"m\"\u003e1.1\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e...\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"g\"\u003eaction=wppm_get_users\u0026amp;proj_id=(SELECT+IF(SUBSTRING(DATABASE(),1,1)=0x77,999,4))\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003eWith a non-existent \u003ccode\u003eproj_id\u003c/code\u003e, the response contains \u003ccode\u003eNone\u003c/code\u003e.\u003c/p\u003e\n\u003cp\u003e\u003cfigure\u003e\u003ca class=\"lightgallery\" href=\"/2025-09-22-cve-2025-39569/res_none.png\" title=\"response none\" data-thumbnail=\"/2025-09-22-cve-2025-39569/res_none.png\" data-sub-html=\"\u003ch2\u003eRes 2\u003c/h2\u003e\u003cp\u003eresponse none\u003c/p\u003e\"\u003e\u003cimg  loading=\"lazy\" src='/2025-09-22-cve-2025-39569/res_none.png' srcset=\"/2025-09-22-cve-2025-39569/res_none_hu_e9b5bb4a8a737aec.webp 800w, /2025-09-22-cve-2025-39569/res_none_hu_a62988b41a8a3e21.webp 1200w, /2025-09-22-cve-2025-39569/res_none_hu_7fe114d6abcf4275.webp 1600w\"  alt=\"response none\" height=\"444\" width=\"682\"\u003e\u003c/a\u003e\u003cfigcaption class=\"image-caption\"\u003eRes 2\u003c/figcaption\u003e\n\u003c/figure\u003e\u003c/p\u003e\n\u003cp\u003e👉 We successfully retrieved the first character of the database name using \u003cstrong\u003eboolean-based SQLi\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eCorrect \u003ccode\u003eproj_id\u003c/code\u003e: response without \u003ccode\u003eNone\u003c/code\u003e\u003c/li\u003e\n\u003cli\u003eWrong \u003ccode\u003eproj_id\u003c/code\u003e: response contains \u003ccode\u003eNone\u003c/code\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003cblockquote\u003e\n  \u003cp\u003eTime-based SQLi could also be used, but dumping large data sets would be slow.\u003c/p\u003e\n\n\u003c/blockquote\u003e\u003ch2 id=\"conclusion\" class=\"headerLink\"\u003e\n    \u003ca href=\"#conclusion\" class=\"header-mark\"\u003e\u003c/a\u003e4 Conclusion\u003c/h2\u003e\u003cp\u003eThe \u003cstrong\u003eCVE-2025-39569\u003c/strong\u003e vulnerability in \u003cstrong\u003eWordPress Taskbuilder\u003c/strong\u003e arises from the missing single quotes \u003ccode\u003e'...'\u003c/code\u003e around user input in SQL queries, allowing user data to be interpreted as valid SQL syntax.\u003c/p\u003e\n\u003cp\u003eThe patch in \u003cstrong\u003ev4.0.2\u003c/strong\u003e fixed this by wrapping \u003ccode\u003e$proj_id\u003c/code\u003e in quotes, ensuring it is always treated as a literal string in SQL.\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eKey Takeaways\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003ePrefer \u003cstrong\u003eprepared statements\u003c/strong\u003e (\u003ccode\u003e$wpdb-\u0026gt;prepare()\u003c/code\u003e in WordPress) over manually inserting variables into queries.\u003c/li\u003e\n\u003cli\u003eFor WordPress plugins, thoroughly test \u003cstrong\u003eAjax endpoints\u003c/strong\u003e, as they are the most common sources of SQLi and XSS.\u003c/li\u003e\n\u003cli\u003eAdministrators should regularly update plugins/themes to receive security patches promptly.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"references\" class=\"headerLink\"\u003e\n    \u003ca href=\"#references\" class=\"header-mark\"\u003e\u003c/a\u003e5 References\u003c/h2\u003e\u003cp\u003e\u003ca href=\"https://portswigger.net/web-security/sql-injection/cheat-sheet\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eSQL Injection Cheat Sheet - PortSwigger\u003c/a\u003e\u003c/p\u003e\n\u003cp\u003e\u003ca href=\"https://patchstack.com/database/wordpress/plugin/taskbuilder/vulnerability/wordpress-taskbuilder-4-0-1-sql-injection-vulnerability?_s_id=cve\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eWordPress Taskbuilder \u0026lt;= 4.0.1 Vulnerable to SQL Injection\u003c/a\u003e\u003c/p\u003e",
        "language": "en"
    },
    {
        "title" : "CVE-2025-39566 Analysis \u0026 POC",
        "date_published" : "2025-09-21T22:27:00+07:00",
        "date_modified" : "2025-10-21T19:11:48+07:00",
        "id" : "http://localhost:1313/2025-09-21-cve-2025-39566/",
        "url" : "http://localhost:1313/2025-09-21-cve-2025-39566/",
        "content_html" : "\u003cp\u003eA vulnerability in the \u003cstrong\u003eHostel\u003c/strong\u003e plugin prior to version \u003cstrong\u003e1.1.5.7\u003c/strong\u003e. Because input is not sanitized properly, this may allow an attacker to interact directly with the database, including but not limited to data exfiltration.\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eCVE ID\u003c/strong\u003e: \u003ca href=\"https://www.cve.org/CVERecord?id=CVE-2025-39566\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCVE-2025-39566\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eProduct\u003c/strong\u003e: \u003ca href=\"https://wordpress.org/plugins/hostel/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eWordPress Hostel Plugin\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eVulnerability Type\u003c/strong\u003e: SQL Injection\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eAffected Versions\u003c/strong\u003e: \u0026lt;= 1.1.5.6\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eCVSS severity\u003c/strong\u003e: 7.6 (High)\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eRequired Privilege\u003c/strong\u003e: Administrator\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"requirements\" class=\"headerLink\"\u003e\n    \u003ca href=\"#requirements\" class=\"header-mark\"\u003e\u003c/a\u003e1 Requirements\u003c/h2\u003e\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eLocal WordPress \u0026amp; Debugging\u003c/strong\u003e: \u003ca href=\"https://w41bu1.github.io/2025-08-21-wordpress-local-and-debugging/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eLocal WordPress and Debugging\u003c/a\u003e.\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eHostel Plugin\u003c/strong\u003e: v1.1.5.6 (vulnerable) and v1.1.5.7 (fixed)\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003ediff tool\u003c/strong\u003e: \u003cstrong\u003emeld\u003c/strong\u003e or any tool capable of comparing two versions to show differences\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"analysis\" class=\"headerLink\"\u003e\n    \u003ca href=\"#analysis\" class=\"header-mark\"\u003e\u003c/a\u003e2 Analysis\u003c/h2\u003e\u003cp\u003eThe root cause is that the application injects data from a \u003cstrong\u003eGET\u003c/strong\u003e request directly into an SQL query while the validation/whitelisting is insufficient.\u003c/p\u003e\n\u003ch3 id=\"patch-diff\" class=\"headerLink\"\u003e\n    \u003ca href=\"#patch-diff\" class=\"header-mark\"\u003e\u003c/a\u003e2.1 Patch Diff\u003c/h3\u003e\u003cp\u003eUse any diff tool to compare the vulnerable version and the patched version.\nA clear difference exists in the file \u003cstrong\u003econtrollers/bookings.php\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eVulnerable version\u003c/strong\u003e:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.9