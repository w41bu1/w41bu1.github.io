e\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"w\"\u003e\u003c/span\u003e\u003cspan class=\"o\"\u003e+\u003c/span\u003e\u003cspan class=\"c1\"\u003e---------+---------+----------------+------------+\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"n\"\u003emeta_id\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"n\"\u003epost_id\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"n\"\u003emeta_key\u003c/span\u003e\u003cspan class=\"w\"\u003e       \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"n\"\u003emeta_value\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"w\"\u003e\u003c/span\u003e\u003cspan class=\"o\"\u003e+\u003c/span\u003e\u003cspan class=\"c1\"\u003e---------+---------+----------------+------------+\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e      \u003c/span\u003e\u003cspan class=\"mi\"\u003e27\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e      \u003c/span\u003e\u003cspan class=\"mi\"\u003e69\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"n\"\u003e_woolentor_css\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"n\"\u003ebody\u003c/span\u003e\u003cspan class=\"p\"\u003e:\u003c/span\u003e\u003cspan class=\"err\"\u003e{}\u003c/span\u003e\u003cspan class=\"w\"\u003e    \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"w\"\u003e\u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e     \u003c/span\u003e\u003cspan class=\"mi\"\u003e687\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e    \u003c/span\u003e\u003cspan class=\"mi\"\u003e1416\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"n\"\u003e_woolentor_css\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e \u003c/span\u003e\u003cspan class=\"n\"\u003ebody\u003c/span\u003e\u003cspan class=\"p\"\u003e:\u003c/span\u003e\u003cspan class=\"err\"\u003e{}\u003c/span\u003e\u003cspan class=\"w\"\u003e    \u003c/span\u003e\u003cspan class=\"o\"\u003e|\u003c/span\u003e\u003cspan class=\"w\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"w\"\u003e\u003c/span\u003e\u003cspan class=\"o\"\u003e+\u003c/span\u003e\u003cspan class=\"c1\"\u003e---------+---------+----------------+------------+\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cul\u003e\n\u003cli\u003eWrite the CSS file into the uploads directory (\u003ccode\u003ewoolentor-css-{post_id}.css\u003c/code\u003e).\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cfigure\u003e\u003ca class=\"lightgallery\" href=\"/2025-10-05-cve-2025-58990/write_css.png\" title=\"Write CSS\" data-thumbnail=\"/2025-10-05-cve-2025-58990/write_css.png\" data-sub-html=\"\u003ch2\u003eWrite CSS\u003c/h2\u003e\u003cp\u003eWrite CSS\u003c/p\u003e\"\u003e\u003cimg  loading=\"lazy\" src='/2025-10-05-cve-2025-58990/write_css.png' srcset=\"/2025-10-05-cve-2025-58990/write_css_hu_f0c535344f685362.webp 800w, /2025-10-05-cve-2025-58990/write_css_hu_98287d0786cfd8f6.webp 1200w, /2025-10-05-cve-2025-58990/write_css_hu_6afd2c7df1ce41e3.webp 1600w\"  alt=\"Write CSS\" height=\"322\" width=\"976\"\u003e\u003c/a\u003e\u003cfigcaption class=\"image-caption\"\u003eWrite CSS\u003c/figcaption\u003e\n\u003c/figure\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003cli\u003e\n\u003cp\u003eIf there is no block (\u003ccode\u003ehas_block = false\u003c/code\u003e):\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eRemove the active flag and CSS meta.\u003c/li\u003e\n\u003cli\u003eDelete the CSS file if it exists.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e👉 The likely attack scenario is a typical \u003cstrong\u003eStored XSS\u003c/strong\u003e: a user with role \u003cstrong\u003econtributor\u003c/strong\u003e (who cannot publish) creates a post and injects an XSS payload into the block CSS. The payload is stored in the \u003cstrong\u003edatabase\u003c/strong\u003e or a \u003cstrong\u003efile\u003c/strong\u003e; a higher-privileged user previews the content before publishing, the payload is loaded/rendered in the browser and executes, causing XSS.\u003c/p\u003e\n\u003cp\u003eTo understand how the data is rendered, search the plugin for \u003ccode\u003e_woolentor_css\u003c/code\u003e. Since CSS is stored in \u003ccode\u003ewp_postmeta\u003c/code\u003e under the \u003ccode\u003emeta_key = _woolentor_css\u003c/code\u003e, the plugin will query this value and insert it directly into HTML.\u003c/p\u003e\n\u003cp\u003e\u003cfigure\u003e\u003ca class=\"lightgallery\" href=\"/2025-10-05-cve-2025-58990/meta_key.png\" title=\"Search Meta Key\" data-thumbnail=\"/2025-10-05-cve-2025-58990/meta_key.png\" data-sub-html=\"\u003ch2\u003eSearch Meta Key\u003c/h2\u003e\u003cp\u003eSearch Meta Key\u003c/p\u003e\"\u003e\u003cimg  loading=\"lazy\" src='/2025-10-05-cve-2025-58990/meta_key.png' srcset=\"/2025-10-05-cve-2025-58990/meta_key_hu_41c2333865581da5.webp 800w, /2025-10-05-cve-2025-58990/meta_key_hu_1c79437b15abfb5a.webp 1200w, /2025-10-05-cve-2025-58990/meta_key_hu_728affefe815c15d.webp 1600w\"  alt=\"Search Meta Key\" height=\"762\" width=\"1588\"\u003e\u003c/a\u003e\u003cfigcaption class=\"image-caption\"\u003eSearch Meta Key\u003c/figcaption\u003e\n\u003c/figure\u003e\u003c/p\u003e\n\u003cp\u003e\u003ccode\u003egenerate_inline_css()\u003c/code\u003e fetches block CSS from \u003cstrong\u003ewp_postmeta\u003c/strong\u003e with \u003ccode\u003emeta_key = _woolentor_css\u003c/code\u003e and from the file \u003ccode\u003ewoolentor-css-{$post_id}.css\u003c/code\u003e — if the file exists it calls \u003ccode\u003eget_contents\u003c/code\u003e and inlines the CSS for the post with the given \u003ccode\u003e$post_id\u003c/code\u003e; otherwise it falls back to \u003cstrong\u003ewp_postmeta\u003c/strong\u003e.\u003c/p\u003e\n\u003cp\u003eThe content is placed inside a \u003ccode\u003e\u0026lt;style type=\u0026quot;text/css\u0026quot;\u0026gt;\u0026lt;/style\u0026gt;\u003c/code\u003e tag.\u003c/p\u003e\n\u003cp\u003eThe \u003ccode\u003eManage_Styles\u003c/code\u003e class registers a \u003cstrong\u003eREST API\u003c/strong\u003e route in the \u003ccode\u003eregister_routes\u003c/code\u003e function:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-closed show-li