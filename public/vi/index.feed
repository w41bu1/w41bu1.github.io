-data sed -i \u003cspan class=\"s1\"\u003e\u0026#39;s/username_here/wordpress/\u0026#39;\u003c/span\u003e /srv/www/wordpress/wp-config.php\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003esudo -u www-data sed -i \u003cspan class=\"s1\"\u003e\u0026#39;s/password_here/\u0026lt;your-password\u0026gt;/\u0026#39;\u003c/span\u003e /srv/www/wordpress/wp-config.php\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cul\u003e\n\u003cli\u003eĐây là 3 dòng thay thế text trong file \u003ccode\u003ewp-config.php\u003c/code\u003e:\n\u003cul\u003e\n\u003cli\u003e\u003ccode\u003edatabase_name_here\u003c/code\u003e =\u0026gt; \u003ccode\u003ewordpress\u003c/code\u003e (tên DB đã tạo ở bước trước)\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003eusername_here\u003c/code\u003e =\u0026gt; \u003ccode\u003ewordpress\u003c/code\u003e (user MySQL đã tạo)\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003epassword_here\u003c/code\u003e =\u0026gt; \u003ccode\u003e\u0026lt;your-password\u0026gt;\u003c/code\u003e (password đã set)\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003eKhi Apache chạy WordPress, nó sẽ đọc file này để biết dùng user nào + DB nào để kết nối MySQL\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003e\u003cstrong\u003eThêm Secret Keys và Salts\u003c/strong\u003e:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\