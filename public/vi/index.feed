 class=\"headerLink\"\u003e\n    \u003ca href=\"#sources--sinks\" class=\"header-mark\"\u003e\u003c/a\u003e63.3 Sources \u0026amp; Sinks\u003c/h3\u003e\u003cp\u003e\u003cstrong\u003eSource:\u003c/strong\u003e \u003ccode\u003eUser-Agent\u003c/code\u003e header (POST \u003ccode\u003e/wp-json/wp-statistics/v2/hit\u003c/code\u003e) — DeviceDetector parse → \u003ccode\u003egetModel()\u003c/code\u003e.\n\u003cstrong\u003eSink:\u003c/strong\u003e \u003ccode\u003eincludes/admin/templates/pages/devices/models.php\u003c/code\u003e — \u003ccode\u003eecho $item-\u0026gt;model\u003c/code\u003e (không \u003ccode\u003eesc_html()\u003c/code\u003e / \u003ccode\u003eesc_attr()\u003c/code\u003e)\u003c/p\u003e\n\u003ch3 id=\"flow\" class=\"headerLink\"\u003e\n    \u003ca href=\"#flow\" class=\"header-mark\"\u003e\u003c/a\u003e63.4 Flow\u003c/h3\u003e\u003col\u003e\n\u003cli\u003eAttacker gửi UA chứa payload XSS trong model\u003c/li\u003e\n\u003cli\u003eModel chứa payload được lưu trong database\u003c/li\u003e\n\u003cli\u003eAdmin mở tab models =\u0026gt; payload chạy.\u003c/li\u003e\n\u003c/ol\u003e\n\u003ch2 id=\"exploit\" class=\"headerLink\"\u003e\n    \u003ca href=\"#exploit\" class=\"header-mark\"\u003e\u003c/a\u003e64 Exploit\u003c/h2\u003e\u003ch3 id=\"proof-of-concept-poc\" class=\"headerLink\"\u003e\n    \u003ca href=\"#proof-of-concept-poc\" class=\"header-mark\"\u003e\u003c/a\u003e64.1 Proof of Concept (PoC)\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003eGửi request chứa XSS payload:\u003c/li\u003e\n\u003c/ul\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:t