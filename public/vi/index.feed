26ldquo;aio-settings.php\u0026rdquo;}\u003c/p\u003e\n\u003cp\u003eNếu \u003ccode\u003e$nonce\u003c/code\u003e không hợp lệ =\u0026gt; nhảy sang nhánh \u003ccode\u003eelse\u003c/code\u003e trả về \u003cstrong\u003eJSON\u003c/strong\u003e báo lỗi chứa \u003ccode\u003e$nonce\u003c/code\u003e.\u003c/p\u003e\n\u003cp\u003eClick \u003ccode\u003e2 references\u003c/code\u003e ta thấy hàm \u003ccode\u003epublic function aio_time_clock_lite_js()\u003c/code\u003e được gọi làm callback cho các action hook:\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-07-cve-2025-6832/ref1.png\"\n    alt=\"Hàm aio_time_clock_lite_js() được gắn vào hai hook Ajax (authenticated \u0026amp; unauthenticated)\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eHàm aio_time_clock_lite_js() được gắn vào hai hook Ajax (authenticated \u0026amp; unauthenticated)\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cul\u003e\n\u003cli\u003e\u003ccode\u003ewp_ajax_aio_time_clock_lite_js\u003c/code\u003e(authenticated).\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003ewp_ajax_nopriv_aio_time_clock_lite_js\u003c/code\u003e(unauthenticated). =\u0026gt; Focus\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"sources--sinks\" class=\"headerLink\"\u003e\n    \u003ca href=\"#sources--sinks\" class=\"header-mark\"\u003e\u003c/a\u003e52.3 Sources \u0026amp; Sinks\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eSource\u003c/strong\u003e: Tham số \u003ccode\u003enonce\u003c/code\u003e lấy trực tiếp từ \u003ccode\u003e$_POST\u003c/code\u003e (unauthenticated request).\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eSink\u003c/strong\u003e: Giá trị \u003ccode\u003enonce\u003c/code\u003e được phản chiếu lại trong \u003ccode\u003eecho json_encode(...)\u003c/code\u003e.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"flow\" class=\"headerLink\"\u003e\n    \u003ca href=\"#flow\" class=\"header-mark\"\u003e\u003c/a\u003e52.4 Flow\u003c/h3\u003e\u003col\u003e\n\u003cli\u003eGửi POST request (unauthenticated) đến \u003ccode\u003e/wp-admin/admin-ajax.php\u003c/code\u003e với các \u003cstrong\u003eparams\u003c/strong\u003e:\u003c/li\u003e\n\u003c/ol\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003etext\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.show-line-numbers]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - h