n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nv\"\u003e$project\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u003c/span\u003e \u003cspan class=\"nv\"\u003e$wpdb\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u0026gt;\u003c/span\u003e\u003cspan class=\"na\"\u003eget_row\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;SELECT * FROM \u003c/span\u003e\u003cspan class=\"si\"\u003e{\u003c/span\u003e\u003cspan class=\"nv\"\u003e$wpdb\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u0026gt;\u003c/span\u003e\u003cspan class=\"na\"\u003eprefix\u003c/span\u003e\u003cspan class=\"si\"\u003e}\u003c/span\u003e\u003cspan class=\"s2\"\u003ewppm_project where id = \u0026#39;\u003c/span\u003e\u003cspan class=\"si\"\u003e$proj_id\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#39;\u0026#34;\u003c/span\u003e \u003cspan class=\"p\"\u003e);\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003eBản vá này đảm bảo rằng giá trị \u003ccode\u003e$proj_id\u003c/code\u003e sau khi escape được coi là \u003cstrong\u003emột chuỗi literal\u003c/strong\u003e, không thể thoát ra khỏi dấu nháy đơn để chèn thêm cú pháp SQL, qua đó ngăn chặn tấn công SQL Injection.\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-09-22-cve-2025-39569/patch_diff.png\"\n    alt=\"patch diff\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003ePatch diff\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003ch3 id=\"how-it-work\" class=\"headerLink\"\u003e\n    \u003ca href=\"#how-it-work\" class=\"header-mark\"\u003e\u003c/a\u003e12.2 How it work?\u003c/h3\u003e\u003cp\u003e\u003cstrong\u003eFile architecture\u003c/strong\u003e:\u003c/p\u003e\n\u003cp\u003eCấu trúc chung của file hiện tại\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-closed show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\