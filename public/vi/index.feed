3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-3\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e\u0026lt;\u003c/span\u003e\u003cspan class=\"nt\"\u003einput\u003c/span\u003e \u003cspan class=\"na\"\u003etype\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;hidden\u0026#34;\u003c/span\u003e \u003cspan class=\"na\"\u003eclass\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;menu-item-title\u0026#34;\u003c/span\u003e \u003cspan class=\"na\"\u003ename\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;menu-item[-5][menu-item-title]\u0026#34;\u003c/span\u003e \u003cspan class=\"na\"\u003evalue\u003c/span\u003e\u003cspan class=\"o\"\u003e=\u003c/span\u003e\u003cspan class=\"s\"\u003e\u0026#34;\u0026lt;script\u0026gt;alert(document.domain)\u0026lt;/script\u0026gt;\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e\u0026gt;\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003eCó 1 điều thú vị ở đây, trình duyệt lấy giá trị đã decode html entity để thêm vào request, biết giá trị từ server trước khi echo ra HTML đã được encode\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-11-cve-2025-58674/htmlett2.png\"\n    alt=\"Trình duyệt decode HTML entity trước khi gửi\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eTrình duyệt decode HTML entity trước khi gửi\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cp\u003e👉 Browser đã decode html entity trước khi hiển thị ra HTML.\u003c/p\u003e\n\u003cp\u003eTrên DOM, sau khi click \u003ckbd\u003eAdd to Menu\u003c/kbd\u003e =\u0026gt; \u003ccode\u003eattachTabsPanelListeners\u003c/code\u003e được gọi và thêm giá trị vừa \u003cstrong\u003eselected\u003c/strong\u003e vào bottom của menu item.\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-11-cve-2025-58674/addbottom.png\"\n    alt=\"Thêm item vào cuối danh sách menu\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eThêm item vào cuối danh sách menu\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cp\u003e👉 \u003ccode\u003eedit-menu-item-title\u003c/code\u003e có giá trị chứa XSS payload. Hàm \u003ccode\u003eupdateParentDropdown\u003c/code\u003e sẽ lấy nó gán cho thẻ \u003ccode\u003e\u0026lt;option\u0026gt;\u003c/code\u003e =\u0026gt; XSS xảy ra\u003c/p\u003e\n\u003ch3 id=\"sources--sinks\" class=\"headerLink\"\u003e\n    \u003ca href=\"#sources--sinks\" class=\"header-mark\"\u003e\u003c/a\u003e2.3 Sources \u0026amp; Sinks\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eSource\u003c/strong\u003e: \u003ccode\u003epost-title\u003c/code\u003e tiêu đề của post\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eSink\u003c/strong\u003e: \u003ccode\u003eparentDropdown.html( $html )\u003c/code\u003e có thể chứa HTML độc hại\u003c/li\u003e\n\u003c/ul\u003e\n\u003cdiv class=\"code-block hi