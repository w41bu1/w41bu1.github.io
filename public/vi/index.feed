tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003ecurl https://wordpress.org/wordpress-6.6.2.tar.gz \u003cspan class=\"p\"\u003e|\u003c/span\u003e sudo -u www-data tar zx -C /srv/www\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cblockquote\u003e\n  \u003cp\u003eCài từ \u003ccode\u003ewordpress.org\u003c/code\u003e là cách chuẩn nhất và ít rủi ro:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eUbuntu có sẵn package \u003cstrong\u003ewordpress\u003c/strong\u003e trong repo. Nhưng nó thường cũ hơn nhiều so với bản chính thức trên \u003ccode\u003ewordpress.org\u003c/code\u003e\u003c/li\u003e\n\u003cli\u003eCộng đồng WordPress chỉ hỗ trợ khi bạn dùng bản chính thức từ \u003ccode\u003ewordpress.org\u003c/code\u003e, vì nếu bạn gặp lỗi do package của Ubuntu thì họ không giải quyết được.\n{: .prompt-info }\u003c/li\u003e\n\u003c/ul\u003e\n\n\u003c/blockquote\u003e\u003ch4 id=\"configure-apache-for-wordpress\" class=\"headerLink\"\u003e\n    \u003ca href=\"#configure-apache-for-wordpress\" class=\"header-mark\"\u003e\u003c/a\u003e123.1.3 Configure Apache for WordPress\u003c/h4\u003e\u003cp\u003eTạo file \u003ccode\u003e/etc/apache2/sites-available/wordpress.conf\u003c/code\u003e cấu hình Apache cho WordPress:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-closed show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.o