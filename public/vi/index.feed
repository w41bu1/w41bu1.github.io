pan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e        $get_params_xu = $get_params;\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e        unset($get_params_xu[\u0026#39;user_ids\u0026#39;]);\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e        $get_params_xu = \\WPDM\\__\\__::sanitize_array($get_params_xu, \u0026#39;safetxt\u0026#39;);\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e        $reset_url = add_query_arg($get_params_xu, \u0026#39;edit.php\u0026#39;);\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e        ?\u0026gt;\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e        \u0026lt;a href=\u0026#34;\u0026lt;?php echo esc_url($reset_url); ?\u0026gt;\u0026#34; class=\u0026#34;clear-btn\u0026#34; title=\u0026#34;\u0026lt;?php _e(\u0026#39;Clear user filter\u0026#39;, \u0026#39;download-manager\u0026#39;); ?\u0026gt;\u0026#34;\u0026gt;\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e            \u0026lt;i class=\u0026#34;fas fa-times\u0026#34;\u0026gt;\u0026lt;/i\u0026gt;\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e        \u0026lt;/a\u0026gt;\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e    \u0026lt;/div\u0026gt;\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e\u0026lt;?php endif; ?\u0026gt;\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-06-cve-2025-10146/patch_diff.png\"\n    alt=\"Patch Diff: sanitized GET parameters and escaped URL\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003ePatch Diff: sanitized GET parameters and escaped URL\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cp\u003eBản vá đã \u003cstrong\u003esanitize\u003c/strong\u003e mảng \u003cstrong\u003eGET params\u003c/strong\u003e bằng \u003ccode\u003esanitize_array\u003c/code\u003e và sử dụng \u003ccode\u003eesc_url\u003c/code\u003e  để \u003cstrong\u003eescape URL\u003c/strong\u003e =\u0026gt; an toàn hơn.\u003c/p\u003e\n\u003ch3 id=\"how-it-work\" class=\"headerLink\"\u003e\n    \u003ca href=\"#how-it-work\" class=\"header-mark\"\u003e\u003c/a\u003e52.2 How It Work?\u003c/h3\u003e\u003cp\u003eTa cần tìm URL thực sự để inject GET params chứa XSS payload.\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003esrc/Admin/views/stats/history.php\u003c/strong\u003e chứa các tag \u003cstrong\u003ephp\u003c/strong\u003e, \u003cstrong\u003eHTML\u003c/strong\u003e và nằm trong \u003cstrong\u003eviews\u003c/strong\u003e cho thấy file này được include ở nơi nào đó trong mã nguồn plugin.\u003c/p\u003e\n\u003cp\u003eTa tìm với từ khóa \u003ccode\u003ehistory.php\u003c/code\u003e trong thư mục plugin\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-06-cve-2025-10146/search1.png\"\n    alt=\"Search results for history.php\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eSearch results for history.php\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cp\u003e👉 Không có kết quả nào khớp. Khả năng cao nó được include động như này \u003ccode\u003e{$file_name}.php\u003c/code\u003e. Ta tìm với regex \u003ccode\u003e\\{.*\\}\\.php\u003c/code\u003e:\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-06-cve-2025-10146/regex.png\"\n    alt=\"Regex search for dynamic includes\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eRegex search for dynamic includes\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cp\u003e\u003cstrong\u003esrc/Admin/views/stats/history.php\u003c/strong\u003e được include trong \u003cstrong\u003esrc/Admin/views/stats.php\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003eURL thực sự để truy cập được khai báo ở đầu file \u003cstrong\u003estats.php\u003c/strong\u003e\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-m