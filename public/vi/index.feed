a-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-128\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003ehttp://localhost/wp-json/woolentor/v1/save_css\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003eĐể biết \u003cstrong\u003enamespace\u003c/strong\u003e này được khai báo ở đâu, ta tiếp tục tìm trong mã nguồn với từ khóa \u003ccode\u003e'woolentor/v1'\u003c/code\u003e:\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-05-cve-2025-58990/name_space.png\"\n    alt=\"Name Space\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eName Space\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cp\u003eCó nhiều kết quả, nhưng vì ta đang phân tích tính năng \u003cstrong\u003eREST API\u003c/strong\u003e, nên tập trung vào file \u003cstrong\u003eApi.php\u003c/strong\u003e.\u003c/p\u003e\n\u003cp\u003e\u003ccode\u003eregister_routes( $namespace )\u003c/code\u003e thuộc class \u003ccode\u003eManage_Styles\u003c/code\u003e yêu cầu tham số \u003ccode\u003e$namespace\u003c/code\u003e nên có thể \u003ccode\u003ewoolentor/v1\u003c/code\u003e được truyền ở đây thông qua thể hiện của class gọi đến hàm. ta tìm với từ khóa \u003ccode\u003eManage_Styles\u003c/code\u003e trong file \u003cstrong\u003eApi.php\u003c/strong\u003e để biết nó được gọi như vậy không.\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-05-cve-2025-58990/callapi.png\"\n    alt=\"Call Api\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eCall Api\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cp\u003e\u003ccode\u003enamespace\u003c/code\u003e chính xác được gọi và truyền như vậy.\u003c/p\u003e\n\u003cp\u003e👉 Như vậy, khi gửi \u003cstrong\u003ePOST\u003c/strong\u003e request đến endpoint \u003ccode\u003ehttp://localhost/wp-json/woolentor/v1/save_css\u003c/code\u003e, callback \u003ccode\u003esave_block_css\u003c/code\u003e được gọi để thêm/sửa block CSS trong file và database.\nKhi truy cập vào post có \u003ccode\u003epost_id\u003c/code\u003e liên quan đến block CSS được lưu, \u003ccode\u003egenerate_inline_css\u003c/code\u003e sẽ lấy nội block CSS và inline CSS trong thẻ \u003ccode\u003e\u0026lt;style type=\u0026quot;text/css\u0026quot;\u0026gt;\u0026lt;/style\u0026gt;\u003c/code\u003e của post.\u003c/p\u003e\n\u003ch2 id=\"exploit\" class=\"headerLink\"\u003e\n    \u003ca href=\"#exploit\" class=\"header-mark\"\u003e\u003c/a\u003e53 Exploit\u003c/h2\u003e\u003ch3 id=\"detect-xss\" class=\"headerLink\"\u003e\n    \u003ca href=\"#detect-xss\" class=\"header-mark\"\u003e\u003c/a\u003e53.1 Detect XSS\u003c/h3\u003e\u003cp\u003eSử dụng user có role \u003cstrong\u003econtributor\u003c/strong\u003e tạo 1 post bất kì, ghi nhớ id của post đó.\u003c/p\u003e\n\u003cp\u003eGửi \u003cstrong\u003ePOST\u003c/strong\u003e request đến endpoint \u003ccode\u003ehttp://localhost/wp-json/woolentor/v1/save_css\u003c/code\u003e với XSS payload\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003ehttp\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.show-line-numbers]:tw-text-fgColor-link \n          print:!tw-hidden\" \n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-2