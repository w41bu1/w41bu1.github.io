w-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nv\"\u003e$label\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u003c/span\u003e \u003cspan class=\"s1\"\u003e\u0026#39;aria-label=\u0026#34;\u0026#39;\u003c/span\u003e \u003cspan class=\"o\"\u003e.\u003c/span\u003e \u003cspan class=\"nx\"\u003esprintf\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e \u003cspan class=\"nx\"\u003eesc_attr__\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e \u003cspan class=\"s1\"\u003e\u0026#39;(%s author archive, opens in a new tab)\u0026#39;\u003c/span\u003e \u003cspan class=\"p\"\u003e),\u003c/span\u003e \u003cspan class=\"nv\"\u003e$author_name\u003c/span\u003e \u003cspan class=\"p\"\u003e)\u003c/span\u003e \u003cspan class=\"o\"\u003e.\u003c/span\u003e \u003cspan class=\"s1\"\u003e\u0026#39;\u0026#34;\u0026#39;\u003c/span\u003e\u003cspan class=\"p\"\u003e;\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cp\u003e\u003ccode\u003eesc_attr__()\u003c/code\u003e sau khi dịch chuỗi và escape HTML thì mới đưa vào \u003ccode\u003esprintf()\u003c/code\u003e để chèn biến \u003ccode\u003e$author_name\u003c/code\u003e =\u0026gt; \u003ccode\u003e$author_name\u003c/code\u003e không được xử lý.\u003c/p\u003e\n\u003cp\u003eTrong phiên bản \u003cstrong\u003epatched\u003c/strong\u003e, \u003ccode\u003e$author_name\u003c/code\u003e được đưa vào \u003ccode\u003esprintf()\u003c/code\u003e trước và sau đó mới được escape HTML bằng \u003ccode\u003eesc_attr()\u003c/code\u003e =\u0026gt; an toàn trước XSS.\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n      