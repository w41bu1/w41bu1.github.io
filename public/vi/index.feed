esome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n      \u003c/button\u003e\n        \n      \u003cbutton \n        class=\"\n          tw-select-none \n          tw-mx-2 \n          tw-block \n          group-[.is-open]:tw-hidden \n          print:!tw-hidden\" \n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-27\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003ehttp://localhost/wp-admin/admin.php?page=wc-admin\u0026amp;path=%2Fcustomize-store\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-10-cve-2025-5062/xss1.png\"\n    alt=\"Sự kiện alert() khi postMessage từ console browser\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eSự kiện alert() khi postMessage từ console browser\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cp\u003e👉 \u003ccode\u003ealert()\u003c/code\u003e được kích hoạt, sử dụng debug trong trình duyệt để xem \u003ccode\u003e5292.js\u003c/code\u003e được tải trong trình duyệt\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-10-cve-2025-5062/debug1.png\"\n    alt=\"5292.js từ debug của browser\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003e5292.js từ debug của browser\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003ch3 id=\"sources--sinks\" class=\"headerLink\"\u003e\n    \u003ca href=\"#sources--sinks\" class=\"header-mark\"\u003e\u003c/a\u003e39.3 Sources \u0026amp; Sinks\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eSource\u003c/strong\u003e: \u003ccode\u003eevent.data\u003c/code\u003e từ \u003ccode\u003ewindow.postMessage\u003c/code\u003e (cụ thể \u003ccode\u003eevent.data.url\u003c/code\u003e)\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eSink\u003c/strong\u003e: \u003ccode\u003ewindow.location.href = event.data.url\u003c/code\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"exploit\" class=\"headerLink\"\u003e\n    \u003ca href=\"#exploit\" class=\"header-mark\"\u003e\u003c/a\u003e40 Exploit\u003c/h2\u003e\u003ch3 id=\"proof-of-concept-poc\" class=\"headerLink\"\u003e\n    \u003ca href=\"#proof-of-concept-poc\" class=\"header-mark\"\u003e\u003c/a\u003e40.1 Proof of Concept (PoC)\u003c/h3\u003e\u003cul\u003e\n\u003cli\u003eTạo trang web với mã nguồn sau:\u003c/li\u003e\n\u003c/ul\u003e\n\u003cdiv class=\"code-block highlight is-closed show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e 