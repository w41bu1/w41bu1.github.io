ps://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n      \u003c/button\u003e\n        \n      \u003cbutton \n        class=\"\n          tw-select-none \n          tw-mx-2 \n          tw-block \n          group-[.is-open]:tw-hidden \n          print:!tw-hidden\" \n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-21\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nf\"\u003eGET\u003c/span\u003e \u003cspan class=\"nn\"\u003e/demo/?terms=1)+AND+(SELECT+1+FROM+(SELECT+SLEEP(5))a)+%23+\u003c/span\u003e \u003cspan class=\"kr\"\u003eHTTP\u003c/span\u003e\u003cspan class=\"o\"\u003e/\u003c/span\u003e\u003cspan class=\"m\"\u003e1.1\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-01-cve-2022-21661/detect.png\"\u003e\u003cfigcaption\u003e\n      \u003ch4\u003eKết quả phản hồi cho thấy truy vấn chậm do payload hoạt động\u003c/h4\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003ch2 id=\"conclusion\" class=\"headerLink\"\u003e\n    \u003ca href=\"#conclusion\" class=\"header-mark\"\u003e\u003c/a\u003e19 Conclusion\u003c/h2\u003e\u003cp\u003eLỗ hổng \u003cstrong\u003eCVE-2022-21661\u003c/strong\u003e trong \u003cstrong\u003eWordPress Core\u003c/strong\u003e trước phiên bản \u003cstrong\u003e5.8.3\u003c/strong\u003e, quay ngược đến tận phiên bản \u003cstrong\u003e3.7.37\u003c/strong\u003e, xuất phát từ việc làm sạch dữ liệu (\u003cstrong\u003esanitization\u003c/strong\u003e) không đúng cách trong \u003ccode\u003eWP_Query\u003c/code\u003e dẫn đến lỗ hổng SQL Injection.\u003c/p\u003e\n\u003ch2 id=\"references\" class=\"headerLink\"\u003e\n    \u003ca href=\"#references\" class=\"header-mark\"\u003e\u003c/a\u003e20 References\u003c/h2\u003e\u003cp\u003e\u003ca href=\"https://portswigger.net/web-security/sql-injection/cheat-sheet\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eSQL Injection cheat sheet - PortSwigger\u003c/a\u003e\u003c/p\u003e\n\u003cp\u003e\u003ca href=\"https://www.cve.org/CVERecord?id=CVE-2022-21661\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCVE-2022-21661 Detail\u003c/a\u003e\u003c/p\u003e\n\u003ch2 id=\"notes\" class=\"headerLink\"\u003e\n    \u003ca href=\"#notes\" class=\"header-mark\"\u003e\u003c/a\u003e21 Notes\u003c/h2\u003e\u003cdiv class=\"footnotes\" role=\"doc-endnotes\"\u003e\n\u003chr\u003e\n\u003col\u003e\n\u003cli id=\"fn:1\"\u003e\n\u003cp\u003eVì patch nằm trong file \u003cstrong\u003esrc/wp-includes/class-wp-tax-query.php\u003c/strong\u003e, file này định nghĩa class \u003ccode\u003eWP_Tax_Query\u003c/code\u003e, chịu trách nhiệm xử lý tham số \u003ccode\u003etax_query\u003c/code\u003e trong \u003ccode\u003eWP_Query\u003c/code\u003e. Nếu có thay đổi trong file này thì gần như chắc chắn nó liên quan đến quá trình \u003cstrong\u003eparse/validate\u003c/strong\u003e của \u003ccode\u003etax_query\u003c/code\u003e.\u0026#160;\u003ca href=\"#fnref:1\" class=\"footnote-backref\" role=\"doc-backlink\"\u003e\u0026#x21a9;\u0026#xfe0e;\u003c/a\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ol\u003e\n\u003c/div\u003e",
        "language": "vi"
    }
    {
        "title" : "CVE-2025-2011 Analysis \u0026 POC",
        "date_published" : "2025-09-30T19:08:00+07:00",
        "date_modified" : "2025-09-30T19:08:00+07:00",
        "id" : "http://localhost:1313/vi/2025-09-30-cve-2025-2011/",
        "url" : "http://localhost:1313/vi/2025-09-30-cve-2025-2011/",
        "content_html" : "\u003cp\u003eLỗ hổng xảy ra trên plugin \u003cstrong\u003eDepicter Slider\u003c/strong\u003e của WordPress trước phiên bản \u003cstrong\u003e3.6.2\u003c/strong\u003e. Điều này có thể cho phép kẻ tấn công trực tiếp tương tác với cơ sở dữ liệu của bạn, bao gồm không giới hạn ở việc đánh cắp thông tin.\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eCVE ID\u003c/strong\u003e: \u003ca href=\"https://www.cve.org/CVERecord?id=CVE-2025-2011\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCVE-2025-2011\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eProduct\u003c/strong\u003e: \u003ca href=\"https://wordpress.org/plugins/depicter/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eWordPress Depicter Slider Plugin\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eVulnerability Type\u003c/strong\u003e: SQL Injection\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eAffected Versions\u003c/strong\u003e: \u0026lt;= 3.6.1\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eCVSS severity\u003c/strong\u003e:  High (9.3)\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eRequired Privilege\u003c/strong\u003e: Unauthenticated\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"requirements\" class=\"headerLink\"\u003e\n    \u003ca href=\"#requirements\" class=\"header-mark\"\u003e\u003c/a\u003e71 Requirements\u003c/h2\u003e\u003cul\u003e\n\u003cli\u003e\u003ca href=\"https://w41bu1.github.io/blog/2025-08-21-wordpress-local-and-debugging/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003eLocal WordPress and Debugging\u003c/strong\u003e\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eDepicter Slider\u003c/strong\u003e:  v3.6.1(vul) và v3.6.2(fix)\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003ediff tool\u003c/strong\u003e: \u003cstrong\u003emeld\u003c/strong\u003e hoặc bất cứ tool nào có thể compare để thấy được sự khác biệt giữa 2 version\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"analysis\" class=\"headerLink\"\u003e\n    \u003ca href=\"#analysis\" class=\"header-mark\"\u003e\u003c/a\u003e72 Analysis\u003c/h2\u003e\u003cp\u003eNguyên nhân cố lõi do ứng dụng chèn trực tiếp dữ liệu từ \u003cstrong\u003eGET\u003c/strong\u003e request vào SQL query mà không có cơ chế kiểm soát chặt chẽ.\u003c/p\u003e\n\u003ch3 id=\"patch-diff\" class=\"headerLink\"\u003e\n    \u003ca href=\"#patch-diff\" class=\"header-mark\"\u003e\u003c/a\u003e72.1 Patch Diff\u003c/h3\u003e\u003cp\u003eDùng diff tool bất kì để so sánh sự khác biệt giữa bản lỗi và bản vá.\nCó sự khác biệt rõ ở file \u003cstrong\u003eapp/src/Controllers/Ajax/LeadsAjaxController.php\u003c/strong\u003e\u003c/p\u003e\n\u003cp\u003e\u003ccode\u003eindex\u003c/code\u003e, \u003ccode\u003elist\u003c/code\u003e, \u003ccode\u003eexport\u003c/code\u003e là 3 hàm đáng chú ý nằm trong class \u003ccode\u003eLeadsAjaxController\u003c/code\u003e\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-closed show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-