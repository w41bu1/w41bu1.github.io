lass=\"n\"\u003epayload_here\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ccode\u003elist\u003c/code\u003e được gọi với duy nhất param \u003ccode\u003es\u003c/code\u003e được thêm vào \u003ccode\u003e$args\u003c/code\u003e, còn lại được set giá trị mặc định\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003egetResults\u003c/code\u003e được gọi với đối số \u003ccode\u003e$args\u003c/code\u003e\u003c/li\u003e\n\u003cli\u003eĐiều kiện \u003ccode\u003eif( ! $args['includeFields'] )\u003c/code\u003e trong \u003ccode\u003egetResults\u003c/code\u003e khi \u003ccode\u003eincludeFields\u003c/code\u003e mặc định là \u003ccode\u003efalse\u003c/code\u003e =\u0026gt; \u003ccode\u003egetLeadsResults\u003c/code\u003e được gọi\u003c/li\u003e\n\u003cli\u003eThực hiện truy vấn gây lỗi SQLi\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"exploit\" class=\"headerLink\"\u003e\n    \u003ca href=\"#exploit\" class=\"header-mark\"\u003e\u003c/a\u003e73 Exploit\u003c/h2\u003e\u003ch3 id=\"detect-sqli\" class=\"headerLink\"\u003e\n    \u003ca href=\"#detect-sqli\" class=\"header-mark\"\u003e\u003c/a\u003e73.1 Detect SQLi\u003c/h3\u003e\u003cp\u003eGửi \u003cstrong\u003eGET request\u003c/strong\u003e chứa payload SQLi.\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\n  \u003cdiv class=\"\n    \n    tw-flex \n    tw-flex-row\n    tw-flex-1 \n    tw-justify-between \n    tw-w-full tw-bg-bgColor-secondary\n    \"\u003e      \n    \u003cbutton \n      class=\"\n        code-block-button\n        tw-mx-2 \n        tw-flex\n        tw-flex-row\n        tw-flex-1\"\n      aria-hidden=\"true\"\u003e\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\