\n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-16\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003ebundle \u003cspan class=\"nb\"\u003eexec\u003c/span\u003e jekyll s\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003ch3 id=\"configuration\" class=\"headerLink\"\u003e\n    \u003ca href=\"#configuration\" class=\"header-mark\"\u003e\u003c/a\u003e39.2 Configuration\u003c/h3\u003e\u003cp\u003eMột số biến cần cấu hình trong \u003ccode\u003e_config.yml\u003c/code\u003e, bao gồm:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ccode\u003elang\u003c/code\u003e: Set language cho website của bạn\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003eurl\u003c/code\u003e: Trỏ đến website của bạn\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003etitle\u003c/code\u003e: Title chính, nằm dưới avatar\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003etagline\u003c/code\u003e: Subtitle, mô tả trang web\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003eavatar\u003c/code\u003e: hỗ trợ local và CORS resources, có thể sử dụng \u003ccode\u003egif\u003c/code\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"comment-feature-via-giscus\" class=\"headerLink\"\u003e\n    \u003ca href=\"#comment-feature-via-giscus\" class=\"header-mark\"\u003e\u003c/a\u003e39.3 Comment feature via Giscus\u003c/h3\u003e\u003cp\u003eTa sử dụng \u003ca href=\"https://giscus.app\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003eGiscus\u003c/strong\u003e\u003c/a\u003e làm hệ thống comment cho website, ngoài ra còn các option khác như: \u003ca href=\"https://disqus.com/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003eDisqus\u003c/strong\u003e\u003c/a\u003e, \u003ca href=\"https://utteranc.es/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003eUtterances\u003c/strong\u003e\u003c/a\u003e, tất cả đều miễn phí.\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eCác bước thực hiện\u003c/strong\u003e:\u003c/p\u003e\n\u003col\u003e\n\u003cli\u003eCài đặt \u003ca href=\"https://github.com/apps/giscus\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003egiscus\u003c/strong\u003e\u003c/a\u003e vào Github.\u003c/li\u003e\n\u003cli\u003eVào \u003cstrong\u003eSettings\u003c/strong\u003e của repository chọn \u003cstrong\u003eGeneral\u003c/strong\u003e và bật \u003cstrong\u003eDiscussions\u003c/strong\u003e để giscus lưu comments vào \u003cstrong\u003eDiscussions\u003c/strong\u003e.\u003c/li\u003e\n\u003cli\u003eNhập repository \u003ccode\u003e\u0026lt;username\u0026gt;/\u0026lt;username\u0026gt;.github.io\u003c/code\u003e, thông báo màu xanh lá xuất hiện khi các tiêu chí ở trên được đáp ứng.\u003c/li\u003e\n\u003cli\u003eChọn thể loại discussion và chủ đề cho website.\u003c/li\u003e\n\u003cli\u003eCấu hình giscus trong \u003ccode\u003e_config.yml\u003c/code\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ccode\u003eprovider\u003c/code\u003e: chọn giscus\u003c/li\u003e\n\u003cli\u003e\u003ccode\u003egiscus\u003c/code\u003e: mapping các biến tương ứng đã làm ở \u003ca href=\"https://github.com/apps/giscus\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003egiscus\u003c/strong\u003e\u003c/a\u003e vào biến \u003ccode\u003egiscus\u003c/code\u003e.\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003c/ol\u003e\n\u003ch3 id=\"customize-the-favicon\" class=\"headerLink\"\u003e\n    \u003ca href=\"#customize-the-favicon\" class=\"header-mark\"\u003e\u003c/a\u003e39.4 Customize the Favicon\u003c/h3\u003e\u003cp\u003eTạo \u003cstrong\u003efavicon\u003c/strong\u003e riêng cho website của bạn, không phải sử dụng \u003cstrong\u003efavicon\u003c/strong\u003e mặc định của themes\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eCác bước thực hiện\u003c/strong\u003e:\u003c/p\u003e\n\u003col\u003e\n\u003cli\u003eTruy cập \u003ca href=\"https://www.favicon-generator.org/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003eFavicon Genarate\u003c/strong\u003e\u003c/a\u003e\u003c/li\u003e\n\u003cli\u003eClick \u003ckbd\u003eBrowse\u003c/kbd\u003e chọn favicon cần tạo, sau đó click \u003ckbd\u003eCreate Favicon\u003c/kbd\u003e để tạo.\u003c/li\u003e\n\u003cli\u003eClick \u003ccode\u003eDownload the generated favicon\u003c/code\u003e để tải các file chứa các favicon về.\u003c/li\u003e\n\u003cli\u003eGiải nén file vừa tải, xóa 2 file dưới đây:\n\u003cul\u003e\n\u003cli\u003ebrowserconfig.xml\u003c/li\u003e\n\u003cli\u003esite.webmanifest\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/li\u003e\n\u003cli\u003eCopy toàn bộ file còn lại và paste vào \u003ccode\u003eassets/img/favicons\u003c/code\u003e(nếu chưa có thì tạo).\u003c/li\u003e\n\u003c/ol\u003e\n\u003ch2 id=\"extends\" class=\"headerLink\"\u003e\n    \u003ca href=\"#extends\" class=\"header-mark\"\u003e\u003c/a\u003e40 Extends\u003c/h2\u003e\u003ch3 id=\"remove-meta-tag-in-footer\" class=\"headerLink\"\u003e\n    \u003ca href=\"#remove-meta-tag-in-footer\" class=\"header-mark\"\u003e\u003c/a\u003e40.1 Remove meta tag in Footer\u003c/h3\u003e\u003cp\u003eCó thể xóa dòng \u003ccode\u003eUsing the Chirpy theme for Jekyll.\u003c/code\u003e bằng các bước sau:\u003c/p\u003e\n\u003col\u003e\n\u003cli\u003eTạo file theo đường dẫn sau \u003ccode\u003e_data/locales/en.yml\u003c/code\u003e.\u003c/li\u003e\n\u003cli\u003eCopy nội dung \u003ca href=\"https://raw.githubusercontent.com/cotes2020/jekyll-theme-chirpy/refs/heads/master/_data/locales/en.yml\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003een.yml\u003c/strong\u003e\u003c/a\u003e và dán vào file vừa tạo.\u003c/li\u003e\n\u003cli\u003eSửa nội dung biến \u003ccode\u003emeta\u003c/code\u003e thành \u003ccode\u003e\u0026quot;\u0026quot;\u003c/code\u003e\u003c/li\u003e\n\u003c/ol\u003e\n\u003ch3 id=\"write-a-post\" class=\"headerLink\"\u003e\n    \u003ca href=\"#write-a-post\" class=\"header-mark\"\u003e\u003c/a\u003e40.2 Write a post\u003c/h3\u003e\u003cp\u003eTham khảo \u003ca href=\"https://chirpy.cotes.page/posts/write-a-new-post/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003erule\u003c/strong\u003e\u003c/a\u003e để viết blog của themes và sử dụng \u003ca href=\"https://markdownlivepreview.com/\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\u003cstrong\u003eLive Preview\u003c/strong\u003e\u003c/a\u003e để quan sát\u003c/p\u003e",
        "language": "vi"
    },
    ]
}
