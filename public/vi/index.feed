ps://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\n      \u003c/button\u003e\n        \n      \u003cbutton \n        class=\"\n          tw-select-none \n          tw-mx-2 \n          tw-block \n          group-[.is-open]:tw-hidden \n          print:!tw-hidden\" \n        disabled\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \n    id=\"codeblock-id-77\" \n    class=\"\n      chroma \n      !tw-block \n      tw-p-0\n      tw-m-0\n      tw-transition-[max-height] \n      tw-duration-500 \n      tw-ease-in-out \n      group-[.is-closed]:!tw-max-h-0 \n      group-[.is-wrap]:tw-text-wrap\n      tw-overflow-y-hidden\n      tw-overflow-x-auto\n      tw-scrollbar-thin\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nf\"\u003eGET\u003c/span\u003e \u003cspan class=\"nn\"\u003e/demo/?terms=1)+AND+(SELECT+1+FROM+(SELECT+SLEEP(5))a)+%23+\u003c/span\u003e \u003cspan class=\"kr\"\u003eHTTP\u003c/span\u003e\u003cspan class=\"o\"\u003e/\u003c/span\u003e\u003cspan class=\"m\"\u003e1.1\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\n\u003c/div\u003e\n\u003cfigure\u003e\u003cimg src=\"/2025-10-01-cve-2022-21661/detect.png\"\u003e\u003cfigcaption\u003e\n      \u003ch4\u003eKết quả phản hồi cho thấy truy vấn chậm do payload hoạt động\u003c/h4\u003e\n    \u003c/figcaption\u003e\n\u003c/figure\u003e\n\n\u003ch2 id=\"conclusion\" class=\"headerLink\"\u003e\n    \u003ca href=\"#conclusion\" class=\"header-mark\"\u003e\u003c/a\u003e75 Conclusion\u003c/h2\u003e\u003cp\u003eLỗ hổng \u003cstrong\u003eCVE-2022-21661\u003c/strong\u003e trong \u003cstrong\u003eWordPress Core\u003c/strong\u003e trước phiên bản \u003cstrong\u003e5.8.3\u003c/strong\u003e, quay ngược đến tận phiên bản \u003cstrong\u003e3.7.37\u003c/strong\u003e, xuất phát từ việc làm sạch dữ liệu (\u003cstrong\u003esanitization\u003c/strong\u003e) không đúng cách trong \u003ccode\u003eWP_Query\u003c/code\u003e dẫn đến lỗ hổng SQL Injection.\u003c/p\u003e\n\u003ch2 id=\"references\" class=\"headerLink\"\u003e\n    \u003ca href=\"#references\" class=\"header-mark\"\u003e\u003c/a\u003e76 References\u003c/h2\u003e\u003cp\u003e\u003ca href=\"https://portswigger.net/web-security/sql-injection/cheat-sheet\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eSQL Injection cheat sheet - PortSwigger\u003c/a\u003e\u003c/p\u003e\n\u003cp\u003e\u003ca href=\"https://www.cve.org/CVERecord?id=CVE-2022-21661\" target=\"_blank\" rel=\"noopener noreferrer\"\u003eCVE-2022-21661 Detail\u003c/a\u003e\u003c/p\u003e\n\u003ch2 id=\"notes\" class=\"headerLink\"\u003e\n    \u003ca href=\"#notes\" class=\"header-mark\"\u003e\u003c/a\u003e77 Notes\u003c/h2\u003e\u003cdiv class=\"footnotes\" role=\"doc-endnotes\"\u003e\n\u003chr\u003e\n\u003col\u003e\n\u003cli id=\"fn:1\"\u003e\n\u003cp\u003eVì patch nằm trong file \u003cstrong\u003esrc/wp-includes/class-wp-tax-query.php\u003c/strong\u003e, file này định nghĩa class \u003ccode\u003eWP_Tax_Query\u003c/code\u003e, chịu trách nhiệm xử lý tham số \u003ccode\u003etax_query\u003c/code\u003e trong \u003ccode\u003eWP_Query\u003c/code\u003e. Nếu có thay đổi trong file này thì gần như chắc chắn nó liên quan đến quá trình \u003cstrong\u003eparse/validate\u003c/strong\u003e của \u003ccode\u003etax_query\u003c/code\u003e.\u0026#160;\u003ca href=\"#fnref:1\" class=\"footnote-backref\" role=\"doc-backlink\"\u003e\u0026#x21a9;\u0026#xfe0e;\u003c/a\u003e\u003c/p\u003e\n\u003c/li\u003e\n\u003c/ol\u003e\n\u003c/div\u003e",
        "language": "vi"
    },
    {
        "title" : "CVE-2025-2011 Analysis \u0026 POC",
